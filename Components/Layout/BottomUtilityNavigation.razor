@inject NavigationManager Navigation
@implements IDisposable
<footer class="utility-shell" aria-label="Utility navigation">
    @if (_isDowntimeOpen)
    {
        <section class="utility-overlay utility-modal" aria-label="Downtime print preparation">
            <header class="utility-overlay-header">
                <div>
                    <p class="utility-kicker">Operational Preparedness</p>
                    <h3>@(IsWardOperationsFoundation ? "Downtime" : "Downtime / Print Preparation")</h3>
                </div>
                <button type="button" class="oncall-close" aria-label="Close downtime" @onclick="CloseDowntime">×</button>
            </header>
            <p class="utility-overlay-copy">@DowntimeDescription</p>
            <div class="utility-card-grid">
                @foreach (var item in ActiveDowntimeModules)
                {
                    <article class="utility-card"><h4>@item</h4><p>Prepared for offline operational continuity.</p></article>
                }
            </div>
            <footer class="utility-overlay-footer">
                <button type="button" class="standard-btn" @onclick="CloseDowntime">Close</button>
                <button type="button" class="standard-btn selected" @onclick="CloseDowntime">Return to prototype</button>
            </footer>
        </section>
    }

    @if (_isPageUpdatesOpen)
    {
        <section class="utility-overlay utility-modal mapping-updates-panel" aria-label="Page Updates">
            <header class="utility-overlay-header">
                <div>
                    <p class="utility-kicker">@_pageUpdateContent.Context</p>
                    <h3>@_pageUpdateContent.Title</h3>
                </div>
                <button type="button" class="oncall-close" aria-label="Close page updates" @onclick="ClosePageUpdates">×</button>
            </header>
            <div class="mapping-updates-content">
                <article class="utility-card">
                    <h4>Foundation scope</h4>
                    <ul>
                        @foreach (var scope in _pageUpdateContent.Scope)
                        {
                            <li>@scope</li>
                        }
                    </ul>
                </article>
                <article class="utility-card">
                    <h4>Current prototype status</h4>
                    <p>@_pageUpdateContent.Status</p>
                </article>
                <article class="utility-card">
                    <h4>Future enhancements / future discovery</h4>
                    <p>@_pageUpdateContent.Future</p>
                </article>
                <article class="utility-card">
                    <h4>Known limitations</h4>
                    <p>@_pageUpdateContent.Limitations</p>
                </article>
                <article class="utility-card">
                    <h4>Recent changes / notes</h4>
                    <p>@_pageUpdateContent.Notes</p>
                </article>
            </div>
        </section>
    }

    @if (_isOnCallOpen)
    {
        <section class="utility-overlay utility-oncall" aria-label="Who's currently on call">
            <header class="utility-overlay-header">
                <div>
                    <p class="utility-kicker">Rapid Access</p>
                    <h3>On Call</h3>
                </div>
                <button type="button" class="oncall-close" aria-label="Close on call" @onclick="CloseOnCall">×</button>
            </header>
            <p class="utility-overlay-copy">@OnCallDescription</p>
            <div class="oncall-list">
                @foreach (var contact in OnCallContacts)
                {
                    <article class="oncall-card">
                        <h4>@contact.Role</h4>
                        <p><strong>@contact.Name</strong></p>
                        <p>@contact.Status</p>
                        <p>@contact.Availability</p>
                        <p>Ext: @contact.Extension</p>
                    </article>
                }
            </div>
            <footer class="utility-overlay-footer">
                <button type="button" class="standard-btn selected" @onclick="OpenDirectory">Open Full Facility Directory</button>
            </footer>
        </section>
    }

    @if (_isDirectoryOpen)
    {
        <section class="utility-overlay utility-modal" aria-label="Full facility directory">
            <header class="utility-overlay-header">
                <div>
                    <p class="utility-kicker">Operational Directory</p>
                    <h3>Full Facility Directory</h3>
                </div>
                <button type="button" class="oncall-close" aria-label="Close directory" @onclick="CloseDirectory">×</button>
            </header>
            <div class="support-search utility-search">
                <span><MudIcon Icon="@Icons.Material.Outlined.Search" Size="Size.Small" /></span>
                <input type="search" placeholder="Search role, team, extension" @bind="_directorySearch" @bind:event="oninput" />
            </div>
            <div class="directory-groups">
                @foreach (var group in FilteredDirectoryGroups)
                {
                    <article class="directory-group">
                        <h4>@group.Name</h4>
                        @foreach (var person in group.People)
                        {
                            <div class="directory-row">
                                <span>@person.Name</span>
                                <span>@person.Role</span>
                                <span>Ext: @person.Extension</span>
                            </div>
                        }
                    </article>
                }
            </div>
        </section>
    }

    @if (_isSupportOpen)
    {
        <section class="utility-overlay support-drawer" aria-label="Support">
            <header class="support-header">
                <MudIcon Icon="@Icons.Material.Outlined.HelpOutline" Size="Size.Small" />
                <h3>Support</h3>
                <button type="button" class="oncall-close" aria-label="Close support" @onclick="CloseSupport">×</button>
            </header>

            <section class="support-summary ward-support-summary">
                <p>Use this prototype support panel to contact support, report a prototype issue or request access/help.</p>
                <button type="button" class="standard-btn">Contact support</button>
                <button type="button" class="standard-btn">Report prototype issue</button>
                <button type="button" class="standard-btn">Request access/help</button>
            </section>
        </section>
    }

    <div class="utility-bar" role="tablist" aria-label="Footer utilities">
        @foreach (var item in ActiveItems)
        {
            var isSelected = item == _activeItem;
            <button type="button" class="utility-tab @(isSelected ? "selected" : null)" role="tab" aria-selected="@isSelected" @onclick="() => SelectItem(item)">@item</button>
        }
    </div>
</footer>

@code {
    private const string PageUpdates = "Page Updates";
    private const string OnCall = "On Call";
    private const string Downtime = "Downtime";
    private const string Support = "Support";

    private readonly string[] HomeItems = [PageUpdates, OnCall, Downtime, Support];
    private readonly string[] MyHubItems = [PageUpdates, Support];
    private readonly string[] BedManagementItems = [PageUpdates, OnCall, Downtime, Support];
    private readonly string[] WardOperationsItems = [PageUpdates, Downtime, Support];
    private readonly string[] AllocationCentreItems = [PageUpdates, OnCall, Support];
    private readonly string[] StandardPlaceholderItems = [PageUpdates, Support];
    private string[] _activeItems = [];
    private PageUpdateContent _pageUpdateContent = PageUpdateContent.Generic;
    private string _currentPath = string.Empty;
    private string _activeItem = string.Empty;
    private bool _isOnCallOpen;
    private bool _isSupportOpen;
    private bool _isDowntimeOpen;
    private bool _isDirectoryOpen;
    private bool _isPageUpdatesOpen;
    private string _directorySearch = string.Empty;
    private string _supportSearch = string.Empty;
    private int _openFaqId = 1;

    private readonly string[] GeneralDowntimeModules =
    [
        "General downtime pack placeholder"
    ];

    private readonly string[] BedManagementDowntimeModules =
    [
        "Capacity summary", "Facility snapshot"
    ];

    private readonly string[] WardFoundationDowntimeModules =
    [
        "Admissions and discharges", "Ward patient lists"
    ];

    private readonly List<OnCallContact> OnCallContacts =
    [
        new("Executive On Call", "A. Morgan", "Available", "Available until 0700", "45111"),
        new("Paediatric Surgery", "Dr Strange", "Available", "Available until 0700", "45555"),
        new("ICU Consultant", "Dr K. Banner", "In theatre", "Cover by registrar until 1830", "45120"),
        new("Pharmacy", "S. Carter", "Available", "Available until 2200", "45770"),
        new("IT Support", "Digital Ops", "Available", "24/7", "45001"),
        new("Facilities", "Engineering Desk", "Responding", "Attending Bed 8BC", "45042"),
        new("Disaster Management", "Command Officer", "Standby", "Escalation only", "45190"),
        new("Security", "Security Control", "Available", "24/7", "45999"),
        new("Patient Flow Coordinator", "N. Singh", "Available", "Available until 1900", "45410")
    ];

    private readonly List<DirectoryGroup> DirectoryGroups =
    [
        new("ICU", [new("J. Wong", "ICU Consultant", "45120")]),
        new("Pharmacy", [new("S. Carter", "After-hours Pharmacist", "45770")]),
        new("Radiology", [new("M. Patel", "Radiology Registrar", "45331")]),
        new("Facilities", [new("Engineering Desk", "Maintenance Coordination", "45042")]),
        new("Patient Transport", [new("Transport Dispatch", "Patient Transport", "45260")]),
        new("Security", [new("Security Control", "Security Operations", "45999")]),
        new("Mental Health", [new("L. Tran", "Mental Health Liaison", "45460")]),
        new("Executive", [new("A. Morgan", "Executive On Call", "45111")]),
        new("NUMs", [new("K. Doyle", "11A NUM", "45411")]),
        new("Bed Management", [new("N. Singh", "Patient Flow Coordinator", "45410")]),
        new("Allied Health", [new("R. Mason", "Allied Health Coordinator", "45388")])
    ];

    private readonly List<FaqItem> Faqs =
    [
        new(1, "Contact support", "Contact the prototype support team for assistance with this workspace."),
        new(2, "Report prototype issue", "Include the page, action, expected result and observed result when reporting an issue."),
        new(3, "Request access/help", "Ask the prototype team for access help or walkthrough support.")
    ];

    private bool IsHome => string.IsNullOrEmpty(_currentPath);
    private bool IsBedManagement => _currentPath.Equals("bed-management", StringComparison.OrdinalIgnoreCase);
    private bool IsWardOperationsFoundation => _currentPath.Equals("ward-operations", StringComparison.OrdinalIgnoreCase);
    private bool IsAllocationCentre => _currentPath.Equals("allocation-centre", StringComparison.OrdinalIgnoreCase);
    private bool IsMappingAdmin => _currentPath.Equals("mapping-admin", StringComparison.OrdinalIgnoreCase);
    private IEnumerable<string> ActiveItems => _activeItems;
    private IEnumerable<string> ActiveDowntimeModules => IsWardOperationsFoundation ? WardFoundationDowntimeModules : IsBedManagement ? BedManagementDowntimeModules : GeneralDowntimeModules;
    private string DowntimeDescription => IsWardOperationsFoundation
        ? "Ward Operations downtime includes admissions and discharges plus ward patient lists for prototype continuity review."
        : IsBedManagement
            ? "Bed Management downtime provides a capacity summary and facility snapshot placeholder for continuity planning."
            : "Home downtime provides a general downtime pack placeholder for prototype continuity planning.";
    private string OnCallDescription => IsAllocationCentre
        ? "Placement escalation contacts placeholder for Allocation Centre support."
        : IsBedManagement
            ? "On-call coordination contacts placeholder for Bed Management support."
            : "Operational escalation contacts placeholder for Home Hub support.";

    private IEnumerable<DirectoryGroup> FilteredDirectoryGroups =>
        DirectoryGroups
            .Select(group => new DirectoryGroup(group.Name, group.People.Where(MatchesSearch).ToList()))
            .Where(group => group.People.Count != 0 || string.IsNullOrWhiteSpace(_directorySearch));

    private IEnumerable<FaqItem> FilteredFaqs =>
        string.IsNullOrWhiteSpace(_supportSearch)
            ? Faqs
            : Faqs.Where(f => f.Question.Contains(_supportSearch, StringComparison.OrdinalIgnoreCase) || f.Answer.Contains(_supportSearch, StringComparison.OrdinalIgnoreCase));

    [Parameter] public bool IsDarkMode { get; set; }

    protected override void OnInitialized()
    {
        RefreshContext();
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        RefreshContext();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshContext()
    {
        _currentPath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
        _activeItems = ResolveUtilityItems(_currentPath);
        _pageUpdateContent = ResolvePageUpdateContent(_currentPath);

        if (!string.IsNullOrEmpty(_activeItem) && !_activeItems.Contains(_activeItem))
        {
            CloseAllUtilities();
        }
    }

    private string[] ResolveUtilityItems(string path) => path.ToLowerInvariant() switch
    {
        "" => HomeItems,
        "myhub" => MyHubItems,
        "bed-management" => BedManagementItems,
        "ward-operations" => WardOperationsItems,
        "allocation-centre" => AllocationCentreItems,
        "mapping-admin" => StandardPlaceholderItems,
        "patient-journey" => StandardPlaceholderItems,
        "scenario-mapping" => StandardPlaceholderItems,
        "connected-apps" => StandardPlaceholderItems,
        _ => StandardPlaceholderItems
    };

    private static PageUpdateContent ResolvePageUpdateContent(string path) => path.ToLowerInvariant() switch
    {
        "" => new("Home Hub Updates", "Home / Hub Home", ["Assistant-first landing experience", "Search-first navigation", "Four operational swimlanes"], "Foundation landing page for the QH Patient Flow Hub prototype.", "Future AI recommendations and workspace preparation remain discovery items.", "Prototype metrics and shortcuts are demonstrators, not production workflows.", "Recent notes: foundation Home Hub utility content standardised."),
        "bed-management" => new("Bed Management Updates", "Bed Management", ["Capacity and coordination overview", "Statewide, HHS, Facility and Ward view levels"], "Foundation Bed Management workspace for current capacity visibility and coordination concepts.", "Forecast and predictive concepts are held for future validation. Future reporting/chat functions are not active foundation utilities.", "Prototype data is illustrative and does not update source systems.", "Recent notes: active utilities limited to Page Updates, On Call, Downtime and Support."),
        "ward-operations" => new("Ward Operations Updates", "Ward Operations", ["R2.1 foundation ward board", "Bed and patient list", "Internal transfer request"], "Foundation Ward Operations board for ward-level operational review.", "Future whiteboard and drag-drop concepts remain future-state.", "No production movement or source-system writeback is implemented.", "Recent notes: downtime is scoped to admissions/discharges and ward patient lists."),
        "allocation-centre" => new("Allocation Centre Updates", "Allocation Centre", ["Allocated, unallocated and pending review", "Date/day view placeholder", "Destination decision-support only"], "Foundation Allocation Centre view for placement review concepts.", "Further allocation workflows and escalation detail require future discovery.", "No direct patient movement is performed from this prototype.", "Recent notes: active utilities limited to Page Updates, On Call and Support."),
        "mapping-admin" => new("Bed Mapping Updates", "Mapping Admin", ["Bed list / bed master mapping layer", "Beds/spaces must be mapped to a ward/bay before patient assignment", "Mapping values do not update source systems"], "Foundation Bed Mapping layer for static bed and space context.", "Future room, bay and physical-space mapping remains a discovery candidate. Bed Managers Chat and Reports are future/support candidates, not active utilities.", "Mapping Admin values are prototype-only and do not write back to source systems.", "Recent notes: Mapping Admin utilities show Page Updates and Support only."),
        "myhub" => new("MyHub Updates", "MyHub", ["Personal workspace placeholder"], "Prototype placeholder for a future personal workspace.", "Future pinned modules, saved layouts and personal shortcuts require future discovery.", "No personalised production workflow is implemented.", "Recent notes: MyHub utilities show Page Updates and Support only."),
        _ => PageUpdateContent.Generic
    };

    private void SelectItem(string item)
    {
        if (!_activeItems.Contains(item))
        {
            CloseAllUtilities();
            return;
        }

        _isOnCallOpen = item == OnCall && !_isOnCallOpen;
        _isDowntimeOpen = item == Downtime && !_isDowntimeOpen;
        _isSupportOpen = item == Support && !_isSupportOpen;
        _isPageUpdatesOpen = item == PageUpdates && !_isPageUpdatesOpen;
        _isDirectoryOpen = false;

        _activeItem = item;
        if (!_isOnCallOpen && !_isDowntimeOpen && !_isSupportOpen && !_isPageUpdatesOpen)
        {
            _activeItem = string.Empty;
        }
    }

    private void CloseAllUtilities()
    {
        _isOnCallOpen = false;
        _isDowntimeOpen = false;
        _isSupportOpen = false;
        _isPageUpdatesOpen = false;
        _isDirectoryOpen = false;
        _activeItem = string.Empty;
    }

    private bool MatchesSearch(DirectoryPerson person)
    {
        if (string.IsNullOrWhiteSpace(_directorySearch)) return true;
        var term = _directorySearch.Trim();
        return person.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
               || person.Role.Contains(term, StringComparison.OrdinalIgnoreCase)
               || person.Extension.Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private void CloseOnCall() { _isOnCallOpen = false; if (_activeItem == OnCall) _activeItem = string.Empty; }
    private void CloseDowntime() { _isDowntimeOpen = false; if (_activeItem == Downtime) _activeItem = string.Empty; }
    private void CloseDirectory() => _isDirectoryOpen = false;
    private void CloseSupport() { _isSupportOpen = false; if (_activeItem == Support) _activeItem = string.Empty; }
    private void ClosePageUpdates() { _isPageUpdatesOpen = false; if (_activeItem == PageUpdates) _activeItem = string.Empty; }
    private void OpenDirectory() => _isDirectoryOpen = true;
    private void ToggleFaq(int id) => _openFaqId = _openFaqId == id ? -1 : id;

    public void Dispose() => Navigation.LocationChanged -= HandleLocationChanged;

    private sealed record OnCallContact(string Role, string Name, string Status, string Availability, string Extension);
    private sealed record DirectoryGroup(string Name, List<DirectoryPerson> People);
    private sealed record DirectoryPerson(string Name, string Role, string Extension);
    private sealed record FaqItem(int Id, string Question, string Answer);
    private sealed record PageUpdateContent(string Title, string Context, string[] Scope, string Status, string Future, string Limitations, string Notes)
    {
        public static PageUpdateContent Generic { get; } = new(
            "Prototype Page Updates",
            "Prototype",
            ["This workspace is a prototype placeholder"],
            "Future design and requirements are still required.",
            "Future workflow design, validation and prioritisation remain discovery activities.",
            "No production workflow is implemented.",
            "Recent notes: generic placeholder utilities show Page Updates and Support only.");
    }
}
