@using QHPFH_ConceptPrototype.Components.BedManagement.Shared

<section class="bm-v3-view bm-v3-view--statewide bm-statewide-dashboard" aria-label="Statewide V3 operational command view">
    <StatewideOperationalStrip State="@State" Snapshot="@Snapshot" OnDetailRequested="OpenDetail" Mode="@BedManagementVersion.V3Operational" />
    <MetricTileRow Snapshot="@Snapshot" AwarenessMode="true" Version="@BedManagementVersion.V3Operational" OnDetailRequested="OpenDetail" />

    <div class="bm-statewide-primary bm-statewide-primary--v3">
        <StatewidePressurePanel State="@State" Snapshot="@Snapshot" />
        <ActionTracker Signals="@Actions" />
        <FlowSwimlanePanel Snapshot="@Snapshot" />
    </div>

    <div class="bm-statewide-coordination bm-statewide-coordination--v3">
        <CoordinationPanel Events="@CoordinationEvents" />
        <InsightCardGrid Signals="@State.Signals" Version="@BedManagementVersion.V3Operational" ContextLabel="System action priorities" />
    </div>
    <div class="bm-v3-emphasis-table bm-statewide-performance"><StatewidePerformanceTable State="@State" Version="@BedManagementVersion.V3Operational" Title="Statewide HHS escalation and cross-system support priorities" /></div>
</section>

<StatewideDetailSlideout State="@State" Snapshot="@Snapshot" DetailKey="@_detailKey" OnClose="CloseDetail" />

@code {
    [Parameter, EditorRequired] public BedManagementState State { get; set; } = default!;
    private string? _detailKey;
    private void OpenDetail(string detailKey) => _detailKey = detailKey;
    private void CloseDetail() => _detailKey = null;
    private CapacitySnapshot Snapshot => BedManagementDemoData.GetStatewideSnapshot();
    private IReadOnlyList<OperationalEvent> CoordinationEvents => State.HhsNetworks.SelectMany(hhs => hhs.Facilities).SelectMany(facility => facility.OperationalEvents).Take(5).ToArray();
    private IReadOnlyList<OperationalSignal> Actions => State.HhsNetworks.SelectMany(hhs => hhs.Facilities).SelectMany(facility => facility.Wards).SelectMany(ward => ward.OperationalSignals).Take(5).ToArray();
}
