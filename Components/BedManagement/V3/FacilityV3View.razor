@using QHPFH_ConceptPrototype.Components.BedManagement.Shared
<section class="bm-v3-view bm-v3-view--facility bm-facility-dashboard" aria-label="Facility V3 operational command view">
<FacilityStatusStrip Facility="@Facility" Snapshot="@Snapshot" Version="@BedManagementVersion.V3Operational" />
<FacilityKpiRow Snapshot="@Snapshot" />
<FacilityCoordinationPanel Version="@BedManagementVersion.V3Operational" />
<div class="bm-facility-two-column bm-facility-two-column--forecast"><FacilityFlowSummary Version="@BedManagementVersion.V3Operational" /><section class="bm-shared-panel bm-facility-forecast"><header><div><h3>Bed Availability Future-state concept · V3 operational prototype</h3><p>Future-state operational signal for ready beds over the next 24 hours.</p></div></header><div class="bm-facility-forecast__chart" aria-label="V3 operational prototype forecast concept rises from 8 to 31 available beds"><span style="--height:26%"><b>Now</b><i>8</i></span><span style="--height:42%"><b>12 PM</b><i>13</i></span><span style="--height:61%"><b>4 PM</b><i>19</i></span><span style="--height:81%"><b>8 PM</b><i>25</i></span><span style="--height:100%"><b>Tomorrow</b><i>31</i></span></div></section></div>
<FacilityOperationalBoard />
<div class="bm-facility-queue-grid"><FacilityQueuePanel Type="Allocation" /><FacilityQueuePanel Type="Cleaning" /><FacilityQueuePanel Type="Transfer" /></div>
<section class="bm-shared-panel bm-facility-reports"><header><div><h3>Quick Reports</h3><p>Operational facility snapshots.</p></div></header><div>@foreach(var report in Reports){<button type="button">@report <span>View</span></button>}</div></section>
</section>
@code { [Parameter, EditorRequired] public Facility Facility { get; set; } = default!; private CapacitySnapshot Snapshot => BedManagementDemoData.GetFacilitySnapshot(Facility.Id)!; private static readonly string[] Reports=["Daily Bed Census","Ward Capacity Report","Flow Constraints Report","Discharge Performance"]; }
