@using QHPFH_ConceptPrototype.Components.BedManagement.Shared
<section class="bm-v2-view bm-v2-view--facility bm-facility-dashboard" aria-label="Facility V2 balanced coordination view">
<FacilityStatusStrip Facility="@Facility" Snapshot="@Snapshot" Version="@BedManagementVersion.V2Balanced" />
<FacilityKpiRow Snapshot="@Snapshot" />
<FacilityCoordinationPanel Version="@BedManagementVersion.V2Balanced" />
<div class="bm-facility-two-column"><FacilityFlowSummary Version="@BedManagementVersion.V2Balanced" /><FacilityCapacityOpportunities /></div>
<FacilityWardPerformanceTable Version="@BedManagementVersion.V2Balanced" />
<section class="bm-shared-panel bm-facility-reports"><header><div><h3>Quick Reports & Insights</h3><p>Lightweight facility reporting shortcuts.</p></div></header><div>@foreach(var report in Reports){<button type="button">@report <span>View</span></button>}</div></section>
</section>
@code { [Parameter, EditorRequired] public Facility Facility { get; set; } = default!; private CapacitySnapshot Snapshot => BedManagementDemoData.GetFacilitySnapshot(Facility.Id)!; private static readonly string[] Reports=["Daily Bed Census","Ward Capacity Report","Flow Constraints Report","Discharge Performance","Admissions Overview"]; }
