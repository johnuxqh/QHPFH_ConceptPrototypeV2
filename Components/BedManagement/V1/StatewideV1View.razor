@using QHPFH_ConceptPrototype.Components.BedManagement.Shared

<section class="bm-v1-view bm-v1-view--statewide bm-statewide-dashboard" aria-label="Statewide V1 data and insights view">
    <StatewideOperationalStrip State="@State" Snapshot="@Snapshot" OnDetailRequested="OpenDetail" Mode="@BedManagementVersion.V1DataInsights" />
    <MetricTileRow Snapshot="@Snapshot" AwarenessMode="true" Version="@BedManagementVersion.V1DataInsights" OnDetailRequested="OpenDetail" />

    <div class="bm-statewide-primary bm-statewide-primary--v1">
        <StatewidePressurePanel State="@State" Snapshot="@Snapshot" />
        <StatewideFlowOverview Snapshot="@Snapshot" Version="@BedManagementVersion.V1DataInsights" OnDetailRequested="OpenDetail" />
    </div>

    <StatewideActivityPanel Version="@BedManagementVersion.V1DataInsights" OnDetailRequested="OpenDetail" />
    <div class="bm-v1-emphasis-table bm-statewide-performance"><StatewidePerformanceTable State="@State" Version="@BedManagementVersion.V1DataInsights" Title="Statewide HHS performance summary" OnViewRequested="OpenHhsDetail" OnEditRequested="OpenEdit" /></div>
</section>

<StatewideDetailSlideout State="@State" Snapshot="@Snapshot" DetailKey="@_detailKey" OnClose="CloseDetail" />
@if (!string.IsNullOrWhiteSpace(_editHhs))
{
    <button type="button" class="bm-statewide-slideout__backdrop" aria-label="Close edit preview" @onclick="CloseEdit"></button>
    <aside class="bm-statewide-slideout bm-statewide-slideout--edit" aria-label="@_editHhs editable coordination dataset">
        <header class="bm-statewide-slideout__header"><div><span>Preview only</span><h2>@_editHhs HHS editable coordination dataset</h2></div><button type="button" class="bm-statewide-slideout__close" aria-label="Close edit preview" @onclick="CloseEdit">×</button></header>
        <div class="bm-statewide-slideout__content">
            <p class="bm-statewide-slideout__note">No data is saved in this prototype.</p>
            <section class="bm-statewide-edit-grid">
                @foreach (var field in EditFields)
                {
                    <label><span>@field.Label</span><input value="@field.Value" readonly /></label>
                }
                <label class="bm-statewide-edit-grid__wide"><span>Coordination note</span><textarea readonly>Review pressure and support requirements at the next statewide coordination check.</textarea></label>
                <label class="bm-statewide-edit-grid__wide"><span>Optional data fields</span><textarea readonly>Facilities over threshold · Cleaning constraints · Last update</textarea></label>
            </section>
        </div>
    </aside>
}

@code {
    [Parameter, EditorRequired] public BedManagementState State { get; set; } = default!;
    private string? _detailKey;
    private string? _editHhs;
    private void OpenDetail(string detailKey) => _detailKey = detailKey;
    private void OpenHhsDetail(string hhs) => _detailKey = $"hhs:{hhs}";
    private void OpenEdit(string hhs) => _editHhs = hhs;
    private void CloseDetail() => _detailKey = null;
    private void CloseEdit() => _editHhs = null;
    private CapacitySnapshot Snapshot => BedManagementDemoData.GetStatewideSnapshot();
    private IReadOnlyList<(string Label, string Value)> EditFields =>
    [
        ("Pressure tier", "Tier 2 · High"), ("Escalation status", "Capacity response active"),
        ("Support action", "State coordination review"), ("Owner", "State Ops"),
        ("Next update", "11:45")
    ];
    private IReadOnlyList<InsightSignal> V1Insights => State.Signals.Where(signal => signal.Id != "state-senior-review").ToArray();
}
