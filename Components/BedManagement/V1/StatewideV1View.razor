@using QHPFH_ConceptPrototype.Components.BedManagement.Shared

<section class="bm-v1-view bm-v1-view--statewide bm-statewide-dashboard" aria-label="Statewide V1 data and insights view">
    <StatewideOperationalStrip State="@State" Snapshot="@Snapshot" OnDetailRequested="OpenDetail" Mode="@BedManagementVersion.V1DataInsights" />
    <MetricTileRow Snapshot="@Snapshot" AwarenessMode="true" Version="@BedManagementVersion.V1DataInsights" OnDetailRequested="OpenDetail" />

    <div class="bm-statewide-primary bm-statewide-primary--v1">
        <StatewidePressurePanel State="@State" Snapshot="@Snapshot" />
        <StatewideFlowOverview Snapshot="@Snapshot" Version="@BedManagementVersion.V1DataInsights" OnDetailRequested="OpenDetail" />
    </div>

    <StatewideActivityPanel Version="@BedManagementVersion.V1DataInsights" OnDetailRequested="OpenDetail" />
    <div class="bm-v1-emphasis-table bm-statewide-performance"><StatewidePerformanceTable State="@State" Version="@BedManagementVersion.V1DataInsights" Title="Statewide HHS performance summary" /></div>
</section>

<StatewideDetailSlideout State="@State" Snapshot="@Snapshot" DetailKey="@_detailKey" OnClose="CloseDetail" />

@code {
    [Parameter, EditorRequired] public BedManagementState State { get; set; } = default!;
    private string? _detailKey;
    private void OpenDetail(string detailKey) => _detailKey = detailKey;
    private void CloseDetail() => _detailKey = null;
    private CapacitySnapshot Snapshot => BedManagementDemoData.GetStatewideSnapshot();
    private IReadOnlyList<InsightSignal> V1Insights => State.Signals.Where(signal => signal.Id != "state-senior-review").ToArray();
}
