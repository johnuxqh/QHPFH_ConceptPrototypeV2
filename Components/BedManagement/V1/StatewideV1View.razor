@using QHPFH_ConceptPrototype.Components.BedManagement.Shared

<section class="bm-v1-view bm-v1-view--statewide bm-statewide-dashboard" aria-label="Statewide V1 data and insights view">
    <StatewideOperationalStrip State="@State" Snapshot="@Snapshot" Mode="@BedManagementVersion.V1DataInsights" />
    <MetricTileRow Snapshot="@Snapshot" AwarenessMode="true" />

    <div class="bm-statewide-primary bm-statewide-primary--v1">
        <StatewidePressurePanel State="@State" Snapshot="@Snapshot" />
        <FlowSwimlanePanel Snapshot="@Snapshot" />
    </div>

    <div class="bm-statewide-insights"><InsightCardGrid Signals="@State.Signals" Version="@BedManagementVersion.V2Balanced" ContextLabel="State insights" /></div>
    <div class="bm-v1-emphasis-table bm-statewide-performance"><PerformanceTable Title="HHS performance summary" Rows="@HhsRows" /></div>
</section>

@code {
    [Parameter, EditorRequired] public BedManagementState State { get; set; } = default!;
    private CapacitySnapshot Snapshot => BedManagementDemoData.GetStatewideSnapshot();
    private IReadOnlyList<PerformanceRow> HhsRows => State.HhsNetworks.Select(hhs =>
    {
        var snapshot = BedManagementDemoData.GetHhsSnapshot(hhs.Id)!;
        var support = snapshot.EscalationStatus == "BAU" ? "Monitor" : "Support required";
        return new PerformanceRow(hhs.Name, $"{snapshot.OccupancyPercentage}%", snapshot.EscalationStatus, $"{support} · {snapshot.AvailableBeds} available · {snapshot.ExpectedAdmissions} admissions vs {snapshot.PlannedDischarges} discharges");
    }).OrderBy(row => row.Status == "BAU").ToArray();
}
