<section class="bm-shared-panel bm-statewide-escalation" aria-label="State Escalation Queue">
    <header><h3>State Escalation Queue</h3><span>@(Version == BedManagementVersion.V3Operational ? "Owner visibility" : "Coordination visibility")</span></header>
    <a class="bm-statewide-panel-link" href="#" @onclick:preventDefault @onclick='() => RequestDetail("status-escalations")'>View all escalations <span aria-hidden="true">→</span></a>
    <div class="bm-statewide-escalation__scroll">
        <table>
            <thead><tr><th>HHS</th><th>Trigger / Reason</th><th>@(Version == BedManagementVersion.V2Balanced ? "Current Tier" : "Tier")</th><th>Status</th>@if (Version == BedManagementVersion.V3Operational) { <th>Owner</th> }<th>Next Update</th></tr></thead>
            <tbody>
                @foreach (var row in Rows)
                {
                    <tr><td><a href="#" @onclick:preventDefault @onclick="() => RequestDetail(row.Key)">@row.Hhs</a></td><td>@row.Reason</td><td><span class="bm-statewide-tier @row.TierClass">@row.Tier</span></td><td><span class="bm-statewide-queue-status @row.StatusClass">@row.Status</span></td>@if (Version == BedManagementVersion.V3Operational) { <td>@row.Owner</td> }<td>@row.NextUpdate</td></tr>
                }
            </tbody>
        </table>
    </div>
    <a class="bm-statewide-panel-link" href="#" @onclick:preventDefault @onclick='() => RequestDetail("status-escalations")'>View all escalations <span aria-hidden="true">→</span></a>
</section>

@code {
    [Parameter] public BedManagementVersion Version { get; set; } = BedManagementVersion.V2Balanced;
    [Parameter] public EventCallback<string> OnDetailRequested { get; set; }
    private static readonly IReadOnlyList<EscalationRow> Rows =
    [
        new("escalation-metro-north", "Metro North", "Cleaning backlog", "Tier 3", "is-extreme", "State review active", "is-review", "QPACH", "10:30 AM"),
        new("escalation-metro-south", "Metro South", "Delayed discharges", "Tier 2", "is-high", "Escalation open", "is-open", "State Ops", "11:00 AM"),
        new("escalation-gold-coast", "Gold Coast", "Elective surge", "Tier 2", "is-high", "Under review", "is-watch", "QPACH", "11:30 AM"),
        new("escalation-cairns", "Cairns & Hinterland", "ED demand", "Tier 1", "is-monitor", "Monitoring", "is-monitor", "State Ops", "12:00 PM"),
        new("escalation-west-moreton", "West Moreton", "Staffing impact", "Tier 1", "is-monitor", "Monitoring", "is-monitor", "State Ops", "12:30 PM")
    ];
    private Task RequestDetail(string key) => OnDetailRequested.InvokeAsync(key);
    private sealed record EscalationRow(string Key, string Hhs, string Reason, string Tier, string TierClass, string Status, string StatusClass, string Owner, string NextUpdate);
}
