@if (IsRichAwareness)
{
    <section class="bm-shared-metrics bm-shared-metrics--awareness bm-shared-metrics--statewide-kpis" aria-label="@DashboardAriaLabel">
        @foreach (var metric in DashboardMetrics)
        {
            <article class="bm-shared-metric bm-statewide-kpi bm-statewide-kpi--@metric.Accent">
                <div class="bm-statewide-kpi__heading">
                    <span class="bm-statewide-kpi__label">@metric.Label</span>
                    @if (CanOpenDetail(metric))
                    {
                        <button type="button" class="bm-statewide-kpi__info bm-statewide-kpi__info--opens" title="@metric.Tooltip" aria-label="Open coordination detail for @metric.Label: @metric.Tooltip" data-tooltip="@metric.Tooltip" @onclick="() => RequestDetail(metric.Key)">
                            <img src="@GetInfoIconPath(metric)" alt="" />
                        </button>
                    }
                    else
                    {
                        <span class="bm-statewide-kpi__info bm-statewide-kpi__info--tooltip" role="img" tabindex="0" title="@metric.Tooltip" aria-label="@metric.Label explanation: @metric.Tooltip" data-tooltip="@metric.Tooltip">
                            <img src="@GetInfoIconPath(metric)" alt="" />
                        </span>
                    }
                </div>
                <div class="bm-statewide-kpi__main">
                    <span class="bm-statewide-kpi__icon" aria-hidden="true"><img src="@GetMetricIconPath(metric)" alt="" /></span>
                    <strong class="bm-statewide-kpi__number">@metric.Value</strong>
                </div>
                <span class="bm-statewide-kpi__subtitle">@metric.Detail</span>
                <span class="bm-statewide-kpi__trend" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span>
            </article>
        }
    </section>
}
else
{
    <section class="bm-shared-metrics @(AwarenessMode ? "bm-shared-metrics--awareness" : null)" aria-label="Capacity metrics">
        @foreach (var metric in Metrics)
        {
            <div class="bm-shared-metric"><span>@metric.Label</span><strong>@metric.Value</strong></div>
        }
    </section>
}

@code {
    [Parameter, EditorRequired] public CapacitySnapshot Snapshot { get; set; } = default!;
    [Parameter] public bool AwarenessMode { get; set; }
    [Parameter] public BedManagementVersion Version { get; set; } = BedManagementVersion.V2Balanced;
    [Parameter] public EventCallback<string> OnDetailRequested { get; set; }
    [Parameter] public bool HhsMode { get; set; }

    private bool IsStatewideAwareness => AwarenessMode && Snapshot.Id == BedManagementDemoData.StateId;
    private bool IsRichAwareness => IsStatewideAwareness || HhsMode;
    private string DashboardAriaLabel => HhsMode ? "HHS capacity metrics" : "Statewide capacity metrics";
    private int DelayedFlowCohort => Snapshot.PendingCleaning + Snapshot.PendingMaintenance + Snapshot.TransferRequests;

    private IReadOnlyList<StatewideMetric> DashboardMetrics => HhsMode ? HhsMetrics : StatewideMetrics;

    private IReadOnlyList<StatewideMetric> HhsMetrics =>
    [
        new("kpi-inpatients", "Inpatients", Snapshot.OccupiedBeds.ToString(), "Patients occupying open beds across the HHS", "Current HHS inpatient load across facilities.", "patient", "default", "blue"),
        new("kpi-available", "Available Beds", Snapshot.AvailableBeds.ToString(), "Ready capacity across HHS facilities", "Open, unoccupied beds visible across HHS facilities.", "open-bed", "green", "green"),
        new("kpi-occupancy", "Occupancy", $"{Snapshot.OccupancyPercentage}%", "Current use of open HHS beds", "Occupied beds compared with open HHS capacity.", "occupied-bed", "orange", "orange"),
        new("kpi-admissions", "Admissions Today", Snapshot.ExpectedAdmissions.ToString(), "Expected admissions in current snapshot", "Expected admissions indicate incoming HHS demand.", "admission", "orange", "orange"),
        new("kpi-delayed", "Delayed Flow Patients", DelayedFlowCohort.ToString(), "Current cross-facility flow constraints", "Delayed flow combines visible turnaround and transfer constraints.", "ddp-flow", "red", "red"),
        new("kpi-discharges", "Predicted Discharges", Snapshot.PlannedDischarges.ToString(), "Planned discharge opportunities today", "Predicted discharges identify capacity expected to become available.", "activity", "green", "green")
    ];

    private IReadOnlyList<StatewideMetric> StatewideMetrics =>
    [
        new("kpi-inpatients", "Inpatients", Snapshot.OccupiedBeds.ToString(), "Patients occupying open beds statewide", "Current occupied beds shows the statewide inpatient load, helping teams understand how much open capacity is already committed.", "patient", "default", "blue"),
        new("kpi-available", "Available Beds", Snapshot.AvailableBeds.ToString(), "Ready capacity across the network", "Available beds are open, unoccupied beds visible now; they matter because they represent immediate placement capacity.", "open-bed", "green", "green"),
        new("kpi-occupancy", "Occupancy", $"{Snapshot.OccupancyPercentage}%", "Current use of open statewide beds", "Occupancy compares occupied beds with open beds, signalling pressure before demand exceeds safe visible capacity.", "occupied-bed", "orange", "orange"),
        new("kpi-demand", "Predicted ED Demand", Snapshot.ExpectedAdmissions.ToString(), "Expected admissions in current snapshot", "Predicted ED demand uses expected admissions to show likely incoming pressure and where coordination may be needed.", "admission", "orange", "orange"),
        new("kpi-delayed", "Delayed Flow Cohort", DelayedFlowCohort.ToString(), "Cleaning, maintenance and transfer constraints", "Delayed flow combines cleaning, maintenance and transfer constraints, highlighting patients or beds that may block movement.", "ddp-flow", "red", "red"),
        new("kpi-discharges", "Discharges Today", Snapshot.PlannedDischarges.ToString(), "Planned discharge opportunities today", "Planned discharges identify capacity that can be protected or accelerated to offset admissions and reduce pressure.", "activity", "green", "green")
    ];

    private bool CanOpenDetail(StatewideMetric metric) => OnDetailRequested.HasDelegate && (Version switch
    {
        BedManagementVersion.V3Operational => true,
        BedManagementVersion.V2Balanced => metric.Key is "kpi-demand" or "kpi-delayed" or "kpi-discharges",
        _ => false
    });

    private Task RequestDetail(string key) => OnDetailRequested.InvokeAsync(key);
    private static string GetInfoIconPath(StatewideMetric metric) =>
        $"images/icons/info-{metric.IconTone}.png";
    
    private static string GetMetricIconPath(StatewideMetric metric) =>
        $"images/icons/{metric.Icon}-{metric.IconTone}.png";
    private IEnumerable<(string Label, string Value)> Metrics => AwarenessMode
        ?
        [
            ("Occupancy", $"{Snapshot.OccupancyPercentage}%"),
            ("Available capacity", Snapshot.AvailableBeds.ToString()),
            ("Expected admissions", Snapshot.ExpectedAdmissions.ToString()),
            ("Discharge opportunity", Snapshot.PlannedDischarges.ToString()),
            ("Transfer concerns", Snapshot.TransferRequests.ToString())
        ]
        :
        [
            ("Physical beds", Snapshot.PhysicalBeds.ToString()), ("Open beds", Snapshot.OpenBeds.ToString()),
            ("Occupied", Snapshot.OccupiedBeds.ToString()), ("Available", Snapshot.AvailableBeds.ToString()),
            ("Pending cleaning", Snapshot.PendingCleaning.ToString()), ("Maintenance", Snapshot.PendingMaintenance.ToString()),
            ("Closed", Snapshot.ClosedBeds.ToString()), ("Occupancy", $"{Snapshot.OccupancyPercentage}%")
        ];

    private sealed record StatewideMetric(string Key, string Label, string Value, string Detail, string Tooltip, string Icon, string IconTone, string Accent);
}
