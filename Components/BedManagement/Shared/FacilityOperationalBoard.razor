<section class="bm-shared-panel bm-facility-table bm-facility-operational-board" id="facility-board" aria-label="Ward operational board"><header><div><h3>Ward Operational Board</h3><p>Live facility view of ward pressure, capacity and next actions.</p></div></header><div class="bm-facility-table__scroll" role="region" aria-label="Ward operational rows" tabindex="0"><table><thead><tr><th>Ward</th><th>Tier</th><th>Open Beds</th><th>Occupied / %</th><th>Expected Admissions</th><th>Actual Discharges</th><th>Delayed</th><th>Next Action</th><th>Coordinator</th><th>Action</th></tr></thead><tbody>@foreach(var row in Rows){<tr><th>@row.Ward</th><td><span class="bm-facility-tier @row.Tone">@row.Tier</span></td><td>@row.Open</td><td><strong>@row.Occupied / @row.Percent%</strong></td><td>@row.Admissions</td><td>@row.Discharges</td><td>@row.Delayed</td><td>@row.Action</td><td>@row.Coordinator</td><td><button type="button">@(row.Delayed>2?"Open":"Review")</button></td></tr>}</tbody></table></div><footer><span>@Rows.Count wards</span><span>Operational board · updated 2 min ago</span></footer></section>
@code {
private IReadOnlyList<Row> Rows => Names.Select((name,index)=>{var open=index is 0 or 1?12+index*4:20+(index%5)*4;var occupied=Math.Min(open,open-index%4);return new Row(name,index==0?"Tier 3":index%5==0?"Tier 2":"Tier 1",open,occupied,(int)Math.Round(occupied*100d/open),1+index%5,index%5,index%4,index%3==0?"Resolve discharge barrier":index%3==1?"Confirm incoming allocation":"Monitor readiness",index%4==0?"Bed Manager":"Flow Coordinator",index==0?"is-red":index%5==0?"is-orange":"is-green");}).ToArray();
private static readonly string[] Names=["PICU","ED SSTA","12A","11A","11B","10A","10B","9A","9B","8A","8BA","8BC","5D","4C","HITH","Jacaranda Place","Ellen Barron Centre"];
private sealed record Row(string Ward,string Tier,int Open,int Occupied,int Percent,int Admissions,int Discharges,int Delayed,string Action,string Coordinator,string Tone);
}
