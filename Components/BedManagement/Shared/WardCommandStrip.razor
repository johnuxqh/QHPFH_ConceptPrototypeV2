<section class="bm-ward-command"><header>Operational Command Strip</header><div>@foreach(var item in Items){<article><strong>@item.Value</strong><span>@item.Label</span><small>@item.Detail</small></article>}<button type="button">＋ Create Action</button></div></section>
@code { [Parameter,EditorRequired] public Ward Ward{get;set;}=default!; [Parameter,EditorRequired] public CapacitySnapshot Snapshot{get;set;}=default!; private IReadOnlyList<Item> Items=>[new("Available Beds",Snapshot.AvailableBeds.ToString(),"Now"),new("Expected Next 2 Hours","3","Likely available"),new("Expected End of Day","7","Forecast"),new("Admissions Expected",Ward.ExpectedAdmissions.ToString(),"Before 14:00"),new("Transfers Pending",Ward.TransferRequests.ToString(),"Internal: 2 · IHT: 1"),new("Cleaning In Progress",Snapshot.PendingCleaning.ToString(),"Next ETA 08:30"),new("Delayed Discharges","3","Requires coordination")]; private sealed record Item(string Label,string Value,string Detail);}
