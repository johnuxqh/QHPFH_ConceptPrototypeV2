<section class="bm-shared-panel bm-hhs-flow" aria-label="HHS flow overview">
    <header><div><h3>@Title</h3><p>Demand, emergency, inpatient and discharge signals across facilities.</p></div></header>
    <div class="bm-hhs-flow__scroll" role="region" aria-label="HHS flow domains"><div class="bm-hhs-flow__grid">
        @foreach (var lane in Lanes)
        {
            <article class="bm-hhs-flow__lane @lane.Tone"><h4>@lane.Name</h4><strong>@lane.Value</strong><span>@lane.Detail</span>
                <dl><div><dt>Facility signal</dt><dd>@lane.Signal</dd></div><div><dt>@(Version == BedManagementVersion.V1DataInsights ? "Regional context" : Version == BedManagementVersion.V3Operational ? "Response / owner" : "Coordination status")</dt><dd>@lane.Response</dd></div><div><dt>Next review</dt><dd>@lane.NextReview</dd></div></dl>
                @if (Version == BedManagementVersion.V2Balanced){<a href="#hhs-performance">View coordination summary</a>}
            </article>
        }
    </div></div>
</section>

@code {
    [Parameter, EditorRequired] public CapacitySnapshot Snapshot { get; set; } = default!;
    [Parameter] public BedManagementVersion Version { get; set; } = BedManagementVersion.V1DataInsights;
    private string Title => Version == BedManagementVersion.V3Operational ? "Flow Overview — Current Serve & Response" : "Flow Overview";
    private IReadOnlyList<FlowLane> Lanes => [
        new("Demand", Snapshot.ExpectedAdmissions.ToString(), "Expected admissions", "Logan ED demand surge", "ED surge review · Regional Flow", "11:00 AM", "is-purple"),
        new("Emergency", "+22%", "Above Logan baseline", "PAH capacity response", "Capacity response · HHS Capacity Team", "10:30 AM", "is-red"),
        new("Inpatient Flow", Snapshot.TransferRequests.ToString(), "Cross-facility transfer requests", "QEII available capacity", "Transfer review · Flow Team", "11:30 AM", "is-blue"),
        new("Discharge & Exit", Snapshot.PlannedDischarges.ToString(), "Predicted discharges", "Redland discharge improving", "Discharge pathway check · Flow Team", "12:00 PM", "is-green")];
    private sealed record FlowLane(string Name, string Value, string Detail, string Signal, string Response, string NextReview, string Tone);
}
