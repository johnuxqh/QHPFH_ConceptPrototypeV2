<section class="bm-shared-panel bm-hhs-activity" aria-label="HHS activity and opportunities">
    <header><div><h3>@Title</h3><p>@Description</p></div></header>
    <div class="bm-hhs-activity__cards">
        @foreach (var item in PrimaryItems)
        {<article class="@item.Tone"><span>@item.Kicker</span><strong>@item.Title</strong><p>@item.Detail</p>@if (Version != BedManagementVersion.V1DataInsights){<dl><div><dt>Owner</dt><dd>@item.Owner</dd></div><div><dt>Status</dt><dd>@item.Status</dd></div><div><dt>Next update</dt><dd>@item.NextUpdate</dd></div></dl>}</article>}
    </div>
    @if (Version != BedManagementVersion.V1DataInsights)
    {
        <div class="bm-hhs-activity__secondary"><h4>@(Version == BedManagementVersion.V3Operational ? "Capacity Redistribution Opportunities" : "Cross-Facility Opportunities")</h4><div>@foreach(var opportunity in Opportunities){<article><strong>@opportunity.Title</strong><span>@opportunity.Facility · @opportunity.Capacity</span><b>@opportunity.Status</b></article>}</div></div>
    }
    @if (Version == BedManagementVersion.V3Operational)
    {<ol class="bm-hhs-timeline">@foreach(var item in Timeline){<li class="@item.Tone"><time>@item.Time</time><span>@item.Label</span></li>}</ol>}
</section>

@code {
    [Parameter] public BedManagementVersion Version { get; set; } = BedManagementVersion.V1DataInsights;
    private string Title => Version switch { BedManagementVersion.V1DataInsights => "HHS Insights", BedManagementVersion.V2Balanced => "HHS Coordination Activity", _ => "HHS Action Tracker" };
    private string Description => Version == BedManagementVersion.V1DataInsights ? "Highest-value regional capacity and flow insights." : Version == BedManagementVersion.V2Balanced ? "Active regional coordination items and cross-facility opportunities." : "Active HHS actions, ownership and next updates.";
    private IReadOnlyList<ActivityItem> PrimaryItems => Version switch {
        BedManagementVersion.V1DataInsights => [new("Capacity insight", "PAH occupancy remains above 95%", "Pressure has persisted for 3 consecutive days.", "", "", "", "is-critical"),new("Demand insight", "Logan ED demand is 22% above baseline", "Demand is creating pressure on regional flow.", "", "", "", "is-high"),new("Performance insight", "QEII discharge performance improved 12%", "Improvement recorded across the last week.", "", "", "", "is-positive"),new("Flow insight", "Redland delayed flow cohort reduced", "Eight fewer delayed flow patients in the current comparison.", "", "", "", "is-positive")],
        BedManagementVersion.V2Balanced => [new("Facility review", "PAH capacity response", "Occupancy above 95% for 3 consecutive days.", "HHS Capacity Team", "Under review", "10:30 AM", "is-critical"),new("Demand review", "Logan ED surge response", "ED demand remains 22% above expected baseline.", "Regional Flow", "Monitoring", "11:00 AM", "is-high"),new("Support opportunity", "QEII capacity available", "Capacity flexibility identified for escalation support.", "Flow Team", "Available", "11:30 AM", "is-positive"),new("Flow improvement", "Redland discharge flow", "Discharge performance continues to improve.", "Flow Team", "Improving", "12:00 PM", "is-positive")],
        _ => [new("Priority 1", "PAH capacity review", "Confirm capacity response and cross-facility support.", "HHS Capacity Team", "Escalation active", "10:30 AM", "is-critical"),new("Priority 1", "Logan ED surge response", "Review demand profile and regional support.", "Regional Flow", "Under review", "11:00 AM", "is-high"),new("Priority 2", "QEII transfer review", "Validate available capacity for supported transfers.", "Flow Team", "In progress", "11:30 AM", "is-positive"),new("Priority 2", "Redland discharge pathway check", "Protect improving discharge flow.", "Flow Team", "Monitoring", "12:00 PM", "is-positive")]
    };
    private IReadOnlyList<Opportunity> Opportunities => [new("Available capacity", "QEII", "8 beds", "Ready for review"),new("Improving discharge flow", "Redland", "6 predicted exits", "Monitor"),new("Stable step-down capacity", "Beaudesert", "4 beds", "Available")];
    private IReadOnlyList<TimelineItem> Timeline => [new("08:15", "HHS Tier 2 response opened", "is-complete"),new("08:45", "PAH capacity review started", "is-complete"),new("09:10", "Logan ED escalation reviewed", "is-current"),new("09:45", "QEII transfer support identified", "is-current"),new("10:30", "Next HHS coordination meeting", "is-next")];
    private sealed record ActivityItem(string Kicker,string Title,string Detail,string Owner,string Status,string NextUpdate,string Tone);
    private sealed record Opportunity(string Title,string Facility,string Capacity,string Status);
    private sealed record TimelineItem(string Time,string Label,string Tone);
}
