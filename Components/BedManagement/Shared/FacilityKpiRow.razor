<section class="bm-facility-kpis" aria-label="Facility capacity metrics">
    @foreach (var metric in Metrics)
    {
        <article class="@metric.Tone"><b aria-hidden="true">@metric.Icon</b><span>@metric.Label</span><strong>@metric.Value</strong><small>@metric.Detail</small><i aria-hidden="true"><em></em><em></em><em></em><em></em><em></em><em></em><em></em></i></article>
    }
</section>
@code {
    [Parameter, EditorRequired] public CapacitySnapshot Snapshot { get; set; } = default!;
    private int BedsPending => Snapshot.PendingCleaning + Snapshot.PendingMaintenance;
    private int DelayedFlow => BedsPending + Snapshot.TransferRequests;
    private IReadOnlyList<Metric> Metrics => [
        new("▥", "Physical Capacity", Snapshot.PhysicalBeds.ToString(), "Total beds", "is-blue"),
        new("▤", "Open Operational Beds", Snapshot.OpenBeds.ToString(), $"{Snapshot.AvailableBeds} available now", "is-green"),
        new("▣", "Occupied Beds", Snapshot.OccupiedBeds.ToString(), $"{Snapshot.OccupancyPercentage}% occupancy", "is-purple"),
        new("⌁", "Beds Pending", BedsPending.ToString(), $"Cleaning: {Snapshot.PendingCleaning} · Maint: {Snapshot.PendingMaintenance}", "is-orange"),
        new("◒", "Operational Pressure", Snapshot.EscalationStatus, "Capacity Response", "is-red"),
        new("●", "Admissions Today", Snapshot.ExpectedAdmissions.ToString(), "ED: 42 · Elective: 35 · IHT: 5", "is-teal"),
        new("◷", "Delayed Flow Patients", DelayedFlow.ToString(), "5.2% of occupied", "is-red")
    ];
    private sealed record Metric(string Icon, string Label, string Value, string Detail, string Tone);
}
