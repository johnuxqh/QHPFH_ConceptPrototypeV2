<section class="bm-shared-panel bm-facility-table" id="facility-board" aria-label="Ward performance table"><header><div><h3>Ward Performance Table</h3><p>Expanded ward capacity, admissions, discharge and flow performance.</p></div></header><div class="bm-facility-table__scroll" role="region" aria-label="Ward performance rows" tabindex="0"><table><thead><tr><th>Ward</th>@if(Version==BedManagementVersion.V2Balanced){<th>Pressure</th>}<th>Open Beds</th><th>Occupied @if(Version==BedManagementVersion.V2Balanced){<text>/ %</text>}</th>@if(Version==BedManagementVersion.V1DataInsights){<th>Review Available</th><th>IHT Arrivals</th><th>Add-On Elective</th>}else{<th>Elective</th><th>ED Admissions</th><th>Add-Ons</th>}<th>Outliers</th><th>Predicted Discharges</th><th>Actual Discharges</th><th>Delayed Discharges</th><th>Catchment</th>@if(Version==BedManagementVersion.V2Balanced){<th>Next Action</th><th>Owner</th>}<th>Action</th></tr></thead><tbody>@foreach(var row in Rows){<tr><th>@row.Ward</th>@if(Version==BedManagementVersion.V2Balanced){<td><span class="bm-facility-tier @row.Tone">@row.Pressure</span></td>}<td>@row.Open</td><td><strong>@row.Occupied@if(Version==BedManagementVersion.V2Balanced){<text> / @row.Percent%</text>}</strong></td><td>@row.Available</td><td>@row.Incoming</td><td>@row.AddOns</td><td>@row.Outliers</td><td>@row.Predicted</td><td>@row.Actual</td><td>@row.Delayed</td><td>@row.Catchment</td>@if(Version==BedManagementVersion.V2Balanced){<td>@row.NextAction</td><td>@row.Owner</td>}<td><button type="button">@(Version==BedManagementVersion.V1DataInsights?"View":"View / Summary")</button></td></tr>}</tbody></table></div><footer><span>@Rows.Count wards</span><span>Facility snapshot · updated 2 min ago</span></footer></section>
@code {
[Parameter] public BedManagementVersion Version {get;set;}=BedManagementVersion.V1DataInsights;
private IReadOnlyList<Row> Rows => Names.Select((name,index)=>{var open= index is 0 or 1 ? 12+index*4 : 20+(index%5)*4;var occupied=Math.Min(open,open-(index%4));var pressure=index is 0 ? "Tier 3" : index%5==0 ? "Tier 2":"Tier 1";return new Row(name,pressure,open,occupied,(int)Math.Round(occupied*100d/open),open-occupied,index%4,index%3,index%2,2+index%6,1+index%5,index%4,index%3==0?"Metro / Statewide":"Metro South",index%3==0?"Review discharge barriers":"Confirm allocation",index%4==0?"Bed Manager":"Flow Coordinator",index is 0?"is-red":index%5==0?"is-orange":"is-green");}).ToArray();
private static readonly string[] Names=["PICU","ED SSTA","12A","11A","11B","10A","10B","9A","9B","8A","8BA","8BC","5D","4C","HITH","Jacaranda Place","Ellen Barron Centre"];
private sealed record Row(string Ward,string Pressure,int Open,int Occupied,int Percent,int Available,int Incoming,int AddOns,int Outliers,int Predicted,int Actual,int Delayed,string Catchment,string NextAction,string Owner,string Tone);
}
