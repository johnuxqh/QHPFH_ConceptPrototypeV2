<section class="bm-shared-panel bm-facility-coordination" aria-label="Facility coordination">
<header><div><h3>@Title</h3><p>@Subtitle</p></div></header>
<div class="bm-facility-coordination__cards">
@foreach (var item in Items)
{
    <article class="@item.Tone"><span>@item.Type</span><strong>@item.Issue</strong><p>@item.Detail</p>@if(Version != BedManagementVersion.V1DataInsights){<dl><div><dt>Owner</dt><dd>@item.Owner</dd></div><div><dt>Status</dt><dd>@item.Status</dd></div><div><dt>Next review</dt><dd>@item.Review</dd></div></dl>}</article>
}
</div>
</section>
@code {
[Parameter] public BedManagementVersion Version {get;set;}=BedManagementVersion.V1DataInsights;
private string Title => Version switch {BedManagementVersion.V1DataInsights=>"Key Facility Insights",BedManagementVersion.V2Balanced=>"Active Facility Coordination",_=>"Operational Command Centre"};
private string Subtitle => Version == BedManagementVersion.V1DataInsights ? "Priority signals for facility bed management review." : "Owned operational issues and the next facility decision point.";
private IReadOnlyList<Item> Items => Version == BedManagementVersion.V3Operational ? [new("Allocation","9 waiting allocation","Incoming demand awaiting ward placement.","Bed Manager","Active","10:15 AM","is-high"),new("Blocked beds","4 beds blocked","Maintenance and discharge barriers visible.","Flow Coordinator","Escalated","10:20 AM","is-red"),new("Readiness","7 awaiting cleaning","Priority turnaround queue assigned.","Support Services","In progress","10:10 AM","is-purple"),new("Transfers","5 unplanned transfers","Ward transfer queue requires review.","Bed Manager","Review","10:30 AM","is-orange"),new("Discharge actions","6 add-on actions","Additional discharge opportunities identified.","Ward Leads","Open","11:00 AM","is-green")] : [new("Critical care","PICU occupancy 100%","Review available capacity and incoming demand.","PICU Flow Coordinator","Active","10:15 AM","is-red"),new("Readiness","TBA Medical cleaning backlog identified","Seven beds pending cleaning across medical wards.","Support Services","In progress","10:20 AM","is-orange"),new("Delayed flow","BA Surgical predicted discharge below baseline","Discharge barriers require bed manager review.","Surgical Flow Coordinator","Under review","10:30 AM","is-purple")];
private sealed record Item(string Type,string Issue,string Detail,string Owner,string Status,string Review,string Tone);
}
