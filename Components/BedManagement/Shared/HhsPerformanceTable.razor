<section class="bm-shared-panel bm-hhs-performance-table" id="hhs-performance" aria-label="Facility performance summary">
<header><div><h3>@Title</h3><p>Facility-level capacity, flow, pressure and regional coordination summary.</p></div></header>
<div class="bm-hhs-performance-table__scroll" role="region" aria-label="Facility performance rows" tabindex="0"><table><thead><tr><th>Facility</th><th>Occupancy</th><th>Available Beds</th><th>Admissions (24h)</th><th>Discharges (24h)</th><th>Delayed Flow</th><th>Pressure Tier</th><th>Trend (24h)</th>@if(Version != BedManagementVersion.V1DataInsights){<th>Coordination Status</th><th>Support Action</th><th>Owner</th><th>Next Update</th>}<th>vs Yesterday</th><th>Action</th></tr></thead><tbody>
@foreach(var row in Rows){<tr><th>@row.Facility</th><td><strong>@row.Occupancy%</strong></td><td>@row.Available</td><td>@row.Admissions</td><td>@row.Discharges</td><td>@row.Delayed</td><td><span class="bm-hhs-tier @row.Tone">@row.Tier</span></td><td>@row.Trend</td>@if(Version != BedManagementVersion.V1DataInsights){<td>@row.Status</td><td>@row.Action</td><td>@row.Owner</td><td>@row.NextUpdate</td>}<td>@row.Variance</td><td><button type="button">@ActionLabel</button></td></tr>}
</tbody></table></div><footer><span>5 facilities</span><span>Updated from current HHS snapshot</span></footer></section>
@code {
[Parameter] public BedManagementVersion Version {get;set;} = BedManagementVersion.V1DataInsights;
private string Title => Version == BedManagementVersion.V3Operational ? "Facility Performance & Coordination" : "Facility Performance Summary";
private string ActionLabel => Version switch {BedManagementVersion.V1DataInsights=>"View",BedManagementVersion.V2Balanced=>"View / Summary",_=>"Review / Open"};
private IReadOnlyList<Row> Rows => [new("PAH",97,4,86,72,18,"Tier 3","↑ pressure","Escalation active","Capacity response","HHS Capacity Team","10:30 AM","+3.2%","is-critical"),new("Logan",91,8,74,61,14,"Tier 2","↑ pressure","Under review","ED surge response","Regional Flow","11:00 AM","+2.1%","is-high"),new("QEII",78,18,42,48,5,"Tier 1","↓ easing","Supporting transfers","Capacity available","Flow Team","11:30 AM","-1.8%","is-normal"),new("Redland",74,12,31,38,6,"Tier 1","↓ improving","Monitoring","Discharge pathway check","Flow Team","12:00 PM","-2.4%","is-improving"),new("Beaudesert",68,9,14,16,2,"Tier 1","→ stable","Stable","On watch","Regional Flow","12:30 PM","-0.3%","is-normal")];
private sealed record Row(string Facility,int Occupancy,int Available,int Admissions,int Discharges,int Delayed,string Tier,string Trend,string Status,string Action,string Owner,string NextUpdate,string Variance,string Tone);
}
