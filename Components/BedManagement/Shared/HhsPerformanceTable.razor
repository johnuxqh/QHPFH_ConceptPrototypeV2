<section class="bm-shared-panel bm-hhs-performance-table bm-statewide-performance-table" id="hhs-performance" aria-label="Facility performance summary">
<header><div><h3>@Title</h3><p>Facility-level capacity, flow, pressure and regional coordination summary.</p></div><div class="bm-statewide-performance-table__utility"><button type="button" class="bm-statewide-performance-table__columns" aria-expanded="@_columnsOpen" @onclick="() => _columnsOpen = !_columnsOpen">⚙ <span>Columns</span></button>@if(_columnsOpen){<div class="bm-statewide-performance-table__chooser"><strong>Columns</strong>@foreach(var c in OptionalColumns){<label><input type="checkbox" checked="@IsVisible(c.Key)" @onchange="_ => ToggleColumn(c.Key)" /> @c.Label</label>}</div>}</div></header>
<div class="bm-hhs-performance-table__scroll" role="region" aria-label="Facility performance rows" tabindex="0"><table><thead><tr>@Header("facility","Facility") @Header("occupancy","Occupancy") @Header("available","Available Beds") @Header("admissions","Admissions (24h)") @Header("discharges","Discharges (24h)") @Header("delayed","Delayed Flow") @Header("tier","Pressure Tier") @Header("trend","Trend (24h)") @foreach(var c in OptionalColumns.Where(c=>IsVisible(c.Key))){@Header(c.Key,c.Label)}<th>Action</th></tr></thead><tbody>
@foreach(var row in PagedRows){<tr><th>@row.Facility</th><td><strong>@row.Occupancy%</strong></td><td>@row.Available</td><td>@row.Admissions</td><td>@row.Discharges</td><td>@row.Delayed</td><td><span class="bm-hhs-tier @row.Tone">@row.Tier</span></td><td>@row.Trend</td>@foreach(var c in OptionalColumns.Where(c=>IsVisible(c.Key))){<td>@OptionalValue(c.Key,row)</td>}<td><button type="button">@ActionLabel</button></td></tr>}
</tbody></table></div><footer class="bm-statewide-performance-table__footer"><label>Rows per page <select value="@_pageSize" @onchange="ChangePageSize"><option>10</option><option>15</option><option>25</option><option>50</option></select></label><span>@StartRow–@EndRow of @SortedRows.Count()</span><div><button type="button" disabled="@(_page==1)" @onclick="()=>_page--">Previous</button><button type="button" disabled="@(_page>=PageCount)" @onclick="()=>_page++">Next</button></div></footer></section>
@code {
[Parameter] public BedManagementVersion Version {get;set;} = BedManagementVersion.V1DataInsights;
private bool _columnsOpen,_descending; private string _sort="facility"; private int _page=1,_pageSize=10; private readonly HashSet<string> _visible=[];
private static readonly (string Key,string Label)[] OptionalColumns=[("status","Coordination Status"),("support","Support Action"),("owner","Owner"),("update","Next Update"),("variance","vs Yesterday")];
private string Title => Version == BedManagementVersion.V3Operational ? "Facility Performance & Coordination" : "Facility Performance Summary"; private string ActionLabel => Version switch {BedManagementVersion.V1DataInsights=>"View",BedManagementVersion.V2Balanced=>"View / Summary",_=>"Review / Open"};
private IReadOnlyList<Row> Rows => [new("PAH",97,4,86,72,18,"Tier 3","↑ pressure","Escalation active","Capacity response","HHS Capacity Team","10:30 AM","+3.2%","is-critical"),new("Logan",91,8,74,61,14,"Tier 2","↑ pressure","Under review","ED surge response","Regional Flow","11:00 AM","+2.1%","is-high"),new("QEII",78,18,42,48,5,"Tier 1","↓ easing","Supporting transfers","Capacity available","Flow Team","11:30 AM","-1.8%","is-normal"),new("Redland",74,12,31,38,6,"Tier 1","↓ improving","Monitoring","Discharge pathway check","Flow Team","12:00 PM","-2.4%","is-improving"),new("Beaudesert",68,9,14,16,2,"Tier 1","→ stable","Stable","On watch","Regional Flow","12:30 PM","-0.3%","is-normal")];
private IEnumerable<Row> SortedRows {get{Func<Row,object> key=_sort switch{"occupancy"=>r=>r.Occupancy,"available"=>r=>r.Available,"admissions"=>r=>r.Admissions,"discharges"=>r=>r.Discharges,"delayed"=>r=>r.Delayed,"tier"=>r=>r.Tier,"trend"=>r=>r.Trend,"status"=>r=>r.Status,"support"=>r=>r.Action,"owner"=>r=>r.Owner,"update"=>r=>r.NextUpdate,"variance"=>r=>r.Variance,_=>r=>r.Facility};return _descending?Rows.OrderByDescending(key):Rows.OrderBy(key);}}
private IEnumerable<Row> PagedRows=>SortedRows.Skip((_page-1)*_pageSize).Take(_pageSize); private int PageCount=>Math.Max(1,(int)Math.Ceiling(Rows.Count/(double)_pageSize)); private int StartRow=>Rows.Count==0?0:((_page-1)*_pageSize)+1; private int EndRow=>Math.Min(_page*_pageSize,Rows.Count);
private RenderFragment Header(string key,string label)=>b=>{b.OpenElement(0,"th");b.OpenElement(1,"button");b.AddAttribute(2,"type","button");b.AddAttribute(3,"onclick",EventCallback.Factory.Create(this,()=>Sort(key)));b.AddContent(4,label+(_sort==key?(_descending?" ↓":" ↑"):""));b.CloseElement();b.CloseElement();}; private void Sort(string key){if(_sort==key)_descending=!_descending;else{_sort=key;_descending=false;}_page=1;} private bool IsVisible(string k)=>_visible.Contains(k); private void ToggleColumn(string k){if(!_visible.Add(k))_visible.Remove(k);} private void ChangePageSize(ChangeEventArgs e){_pageSize=int.TryParse(e.Value?.ToString(),out var n)?n:10;_page=1;} private static string OptionalValue(string k,Row r)=>k switch{"status"=>r.Status,"support"=>r.Action,"owner"=>r.Owner,"update"=>r.NextUpdate,"variance"=>r.Variance,_=>""};
private sealed record Row(string Facility,int Occupancy,int Available,int Admissions,int Discharges,int Delayed,string Tier,string Trend,string Status,string Action,string Owner,string NextUpdate,string Variance,string Tone);
}
