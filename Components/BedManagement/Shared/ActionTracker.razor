<section class="bm-shared-panel" aria-label="Action tracker">
    <header><h3>Action tracker</h3><span>@Signals.Count actions</span></header>
    <div class="bm-shared-list">
        @foreach (var item in Signals.Take(5)) { <div><span class="bm-shared-status">@item.Severity</span><p><strong>@item.Label</strong> · @item.Detail</p><small>@item.Owner · @item.DueLabel</small></div> }
        @if (Signals.Count == 0) { <p class="bm-shared-empty">No tracked actions.</p> }
    </div>
</section>
@code { [Parameter] public IReadOnlyList<OperationalSignal> Signals { get; set; } = []; }
