<section class="bm-shared-panel" aria-label="Flow summary">
    <header><h3>Flow summary</h3><span class="bm-shared-status">@Snapshot.EscalationStatus</span></header>
    <div class="bm-shared-swimlanes">
        <div><span>Expected admissions</span><strong>@Snapshot.ExpectedAdmissions</strong></div>
        <div><span>Planned discharges</span><strong>@Snapshot.PlannedDischarges</strong></div>
        <div><span>Transfer requests</span><strong>@Snapshot.TransferRequests</strong></div>
        <div><span>Available beds</span><strong>@Snapshot.AvailableBeds</strong></div>
    </div>
</section>

@code { [Parameter, EditorRequired] public CapacitySnapshot Snapshot { get; set; } = default!; }
