<section class="bm-shared-panel bm-facility-opportunities" aria-label="Capacity opportunities"><header><div><h3>Capacity Opportunities</h3><p>Potential capacity becoming available for allocation.</p></div></header><div>@foreach(var item in Items){<article class="@item.Tone"><span>@item.Label</span><strong>@item.Value</strong><small>@item.Detail</small></article>}</div></section>
@code { private IReadOnlyList<Item> Items => [new("Constrained Beds","14","Cleaning, maintenance or blocked","is-red"),new("Pending Allocation","9","Bed Manager review","is-orange"),new("Predicted Discharges","31","Expected today","is-green"),new("Not Yet Allocated","12","Available opportunity","is-blue"),new("Total Expected","43","Capacity through today","is-purple")]; private sealed record Item(string Label,string Value,string Detail,string Tone); }
