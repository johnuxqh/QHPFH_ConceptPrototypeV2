@inject NavigationManager Navigation

<section class="home-dashboard" aria-label="QH Patient Flow Hub home dashboard">
    <section class="home-assistant" aria-labelledby="home-assistant-title">
        <div class="home-assistant__profile">
            <p class="home-eyebrow">PFH Assistant</p>
            <h1 id="home-assistant-title">Good morning Dr Steven Strange 👋</h1>
            <p class="home-date">It’s Tuesday 24 February</p>
            <p class="home-updated">Last updated: <strong>09:42</strong></p>
            <div class="home-chip-row" aria-label="Usual assignment">
                <span>Queensland Children’s Hospital (QCH)</span>
                <span>Surgical Division</span>
                <span>Ward 8A</span>
            </div>
        </div>

        <div class="home-assistant__search">
            <h2>What would you like to do today?</h2>
            <label class="home-search-box" aria-label="Ask PFH Assistant">
                <input placeholder="Ask anything… e.g. “Show Ward 8A”, “Find patient Sarah Jones”, “Allocate ED admissions”" />
                <button type="button" aria-label="Search">➜</button>
            </label>
            <div class="home-action-tiles" aria-label="Popular actions">
                <button type="button" @onclick='() => Navigation.NavigateTo("patient-journey")'>Find Patient</button>
                <button type="button" @onclick='() => Navigation.NavigateTo("ward-operations")'>View Ward</button>
                <button type="button" @onclick='() => Navigation.NavigateTo("bed-management")'>Bed Management</button>
                <button type="button" @onclick='() => Navigation.NavigateTo("allocation-centre")'>Allocate Admissions</button>
                <button type="button" @onclick='() => Navigation.NavigateTo("delayed-discharge")'>Delayed Discharge</button>
                <button type="button">More</button>
            </div>
            <div class="home-prepare-prompt">
                <p>It’s Tuesday and you usually work in Ward 8A Surgical. Would you like me to prepare your workspace for today?</p>
                <div>
                    <button type="button" class="home-primary-action" @onclick='() => Navigation.NavigateTo("ward-operations")'>Yes, prepare my workspace</button>
                    <button type="button" class="home-secondary-action">Choose another location</button>
                </div>
            </div>
        </div>

        <aside class="home-learning" aria-label="Learning navigation">
            <h2>Learning navigation</h2>
            <section>
                <h3>Recently used</h3>
                <a href="ward-operations">Ward Operations — 8A Surgical</a>
                <a href="bed-management">Bed Management — QCH</a>
                <a href="allocation-centre">Allocation Centre — Metro South</a>
            </section>
            <section>
                <h3>Suggested for today</h3>
                <p>Ward 8A usually reviewed on Tuesdays</p>
                <p>Metro South pressure increased overnight</p>
                <p>3 patients waiting in ED &gt; 30 mins</p>
            </section>
        </aside>
    </section>

    <section class="home-operational-overview" aria-labelledby="operational-overview-title">
        <div class="home-section-heading">
            <p class="home-eyebrow">Operational Overview</p>
            <h2 id="operational-overview-title">Today’s statewide flow signals</h2>
        </div>
        <div class="home-swimlanes">
            <article class="home-swimlane-card"><header><p>DEMAND</p><h3>Pre-Hospital &amp; Arrivals</h3></header><div class="home-map-placeholder"><span>QAS Demand by HHS</span></div><div class="home-legend"><span class="high">High</span><span class="elevated">Elevated</span><span class="moderate">Moderate</span><span class="normal">Normal</span><span class="low">Low</span></div><div class="home-two-col"><section><h4>Top QAS Delays</h4><p>RBWH <strong>82 mins</strong></p><p>Logan <strong>64 mins</strong></p><p>PAH <strong>52 mins</strong></p></section><section><h4>Avg Ambulance POST</h4><p>Metro South <strong>27 mins</strong></p><p>Metro North <strong>24 mins</strong></p><p>Gold Coast <strong>23 mins</strong></p><p>Sunshine Coast <strong>22 mins</strong></p></section></div><a href="hospital-overview">View full demand</a></article>
            <article class="home-swimlane-card"><header><p>EMERGENCY</p><h3>ED Capacity &amp; Insights</h3></header><div class="home-metric-feature"><span>ED Presentations Yesterday</span><strong>2,842 <b class="up">↑ 8%</b></strong></div><div class="home-metric-grid"><p>Patients in ED Now <strong>49 ↑</strong></p><p>Waiting Room <strong>22 ↑</strong></p><p>AWAs <strong>15 ↓</strong></p><p>ED Beds Available <strong>5</strong></p></div><h4>Capacity Score</h4><div class="home-capacity-bar"><span style="width:78%"></span></div><a href="hospital-overview">View ED detail</a></article>
            <article class="home-swimlane-card"><header><p>INPATIENT FLOW</p><h3>Bed Capacity &amp; Insights</h3></header><div class="home-metric-feature"><span>Total Inpatients in Hospital</span><strong>5,334 <b class="down">↓ 2%</b></strong></div><div class="home-gauge"><span style="--value:90%">90%</span></div><div class="home-metric-grid"><p>Elective Admissions Today <strong>146</strong></p><p>Day Cases Today <strong>132</strong></p><p>OPD Appointments Today <strong>1,248</strong></p><p>Interhospital Transfers Today <strong>56</strong></p></div><a href="bed-and-ward-hub">View inpatient flow</a></article>
            <article class="home-swimlane-card"><header><p>DISCHARGE &amp; EXIT</p><h3>Delayed Discharge &amp; Community</h3></header><div class="home-line-chart"><span>Predicted Discharges: <strong>252</strong></span></div><div class="home-metric-feature compact"><span>Patients on Hospital in the Home</span><strong>124 <b class="down">↓ 5%</b></strong></div><h4>Delayed Discharge Cohort Top 5</h4><p>Aged Care Placement <strong>12</strong></p><p>NDIS / Community Support <strong>9</strong></p><p>Transport <strong>7</strong></p><p>Guardianship / Consent <strong>5</strong></p><p>Pharmacy / Meds Access <strong>4</strong></p><a href="delayed-discharge">View discharge hub</a></article>
        </div>
    </section>

    <section class="home-bottom-panels" aria-label="Home supporting panels">
        <article><h3>Recently Used</h3><a href="ward-operations">Ward Operations 8A Surgical</a><a href="bed-management">Bed Management QCH</a><a href="allocation-centre">Allocation Centre Metro South</a><a href="patient-journey">Patient Journey Recent Patients</a><a href="delayed-discharge">Delayed Discharge All Facilities</a></article>
        <article><h3>Suggested for Today</h3><p>Ward 8A usually reviewed on Tuesdays <span>Recommended</span></p><p>Metro South pressure increased overnight <span>High priority</span></p><p>3 patients waiting in ED &gt; 30 mins <span>Action needed</span></p></article>
        <article><h3>Operational Notes</h3><p>Metro South demand increasing</p><p>Surgical admissions trending high</p><p>Discharge flow slowing after 2pm</p><p>High pressure expected this evening</p><button type="button">Add Note</button></article>
        <article><h3>Shortcuts / Key</h3><a href="patient-journey">Patient Journey</a><a href="bed-and-ward-hub">Bed &amp; Ward Operations</a><a href="bed-management">Bed Management</a><a href="allocation-centre">Allocation Centre</a><a href="scenario-mapping">Scenario Mapping</a><a href="connected-apps">Connected Apps</a></article>
    </section>
</section>
