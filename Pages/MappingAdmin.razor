@page "/mapping-admin"
@using Microsoft.AspNetCore.Components

<section class="page-shell-card bed-mgmt-page mapping-admin-page">
    <header class="mapping-admin-hero">
        <div class="mapping-admin-hero__copy">
            <p class="utility-kicker">Administration prototype</p>
            <h2>Mapping Admin</h2>
            <p>Maintain the bed mapping list that defines which beds and spaces exist, what they are capable of, and which ward or bay they are mapped into.</p>
            <p class="mapping-admin-secondary">Operational teams use this mapping before patients can be assigned to beds in Bed Management, Ward Operations or Allocation Centre.</p>
            <div class="mapping-admin-note">Prototype mapping changes are recorded locally for review and do not update source systems.</div>
        </div>

        <section class="mapping-profile-panel" aria-label="Current user profile scope">
            <div><span>HHS</span><strong>Children’s Health Queensland HHS</strong></div>
            <div><span>HHS abbreviation</span><strong>CHQ</strong></div>
            <div><span>HHS code</span><strong>CHQHHS</strong></div>
            <div><span>Facility</span><strong>Queensland Children’s Hospital</strong></div>
            <div><span>Facility abbreviation</span><strong>QCH</strong></div>
            <div><span>Facility code</span><strong>QCH</strong></div>
        </section>
    </header>

    @if (!string.IsNullOrWhiteSpace(ConfirmationMessage))
    {
        <div class="mapping-confirmation">@ConfirmationMessage</div>
    }

    <section class="mapping-summary" aria-label="Bed Mapping summary counts">
        <div><span>Possible beds/spaces</span><strong>20</strong><em>Prototype facility capacity count</em></div>
        <div><span>Currently mapped</span><strong>10</strong><em>Mapped to selected ward context</em></div>
        <div><span>Available to map</span><strong>10</strong><em>Beds/spaces not yet mapped here</em></div>
        <div><span>Surge / temporary capable</span><strong>2</strong><em>Mapping capability, not live occupancy</em></div>
    </section>

    <div class="mapping-admin-grid mapping-admin-grid--foundation">
        <section class="mapping-hierarchy-panel" aria-label="Mapping hierarchy">
            <div class="mapping-panel-heading">
                <div>
                    <p class="utility-kicker">Mapped scope</p>
                    <h3>Mapping Hierarchy</h3>
                </div>
                <span>HHS → Facility → Division → Ward → Bed</span>
            </div>

            <div class="mapping-tree" role="tree" aria-label="Children's Health Queensland HHS mapping tree">
                <div class="mapping-tree-row level-0 static"><span>▾</span><strong>Children’s Health Queensland HHS</strong><em>HHS</em></div>
                <div class="mapping-tree-row level-1 static"><span>▾</span><strong>Queensland Children’s Hospital</strong><em>Facility</em></div>
                @foreach (var division in Divisions)
                {
                    <button type="button" class="mapping-tree-row level-2 @(IsSelected(division) ? "selected" : null)" @onclick="() => SelectDivision(division)">
                        <span>▾</span><strong>@division.Name</strong><em>Division</em>
                    </button>
                    @foreach (var ward in Wards.Where(ward => ward.Division == division.Name))
                    {
                        <button type="button" class="mapping-tree-row level-3 @(IsSelected(ward) ? "selected" : null)" @onclick="() => SelectWard(ward)">
                            <span>▾</span><strong>@ward.Name</strong><em>Ward</em>
                        </button>
                        @foreach (var bed in Beds.Where(bed => bed.Ward == ward.Name))
                        {
                            <button type="button" class="mapping-tree-row level-4 @(IsSelected(bed) ? "selected" : null)" @onclick="() => SelectBed(bed)">
                                <span>•</span><strong>@bed.Name</strong><em>Bed</em>
                            </button>
                        }
                    }
                }
            </div>
        </section>

        <section class="mapping-records-panel" aria-label="Mapped records">
            <div class="mapping-panel-heading">
                <div>
                    <p class="utility-kicker">Reference records</p>
                    <h3>Mapped Records</h3>
                </div>
                <span>Bed Mapping extract view</span>
            </div>
            <div class="mapping-record-tabs" role="tablist" aria-label="Mapped record types">
                <button type="button">Divisions</button>
                <button type="button">Wards</button>
                <button type="button" class="active">Beds</button>
            </div>
            <div class="mapping-record-tools">
                <input aria-label="Search mapped records" placeholder="Search mapped records..." />
                <button type="button">Filters</button>
            </div>
            <div class="mapping-record-table-wrap">
                <table class="mapping-record-table">
                    <thead>
                        <tr><th>Bed</th><th>Ward</th><th>Division</th><th>Ward Type</th><th>Ward Group</th><th>Bed Type</th><th>Specialist Type</th><th>Attributes</th><th>HBCIS Status</th><th>Operational Status</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var bed in Beds)
                        {
                            <tr class="@(SelectedEntityType == "Bed" && SelectedBed == bed ? "mapping-selected" : null)">
                                <td>@bed.Name</td><td>@bed.Ward</td><td>@GetWardForBed(bed).Division</td><td><span class="mapping-table-chip">@GetWardForBed(bed).Type</span></td><td><span class="mapping-table-chip">@GetWardForBed(bed).Group</span></td><td><span class="mapping-table-chip">@bed.Type</span></td><td><span class="mapping-table-chip">@GetWardForBed(bed).SpecialistType</span></td><td>@FormatAttributes(bed.Attributes)</td><td><span class="mapping-table-chip mapping-source-chip">@bed.HbcisStatus</span></td><td><span class="mapping-table-chip mapping-operational-chip">@bed.OperationalStatus</span></td><td><button type="button" @onclick="() => SelectBed(bed)">View / Edit</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <aside class="mapping-detail-panel" aria-label="Selected mapping details">
            <div class="mapping-detail-header">
                <div>
                    <p class="utility-kicker">Selected Mapping Details</p>
                    <h3>@SelectedEntityName</h3>
                </div>
                <div class="mapping-detail-chips"><span>@SelectedEntityType</span><span>Active</span></div>
            </div>
            @if (!string.IsNullOrWhiteSpace(ValidationMessage)) { <p class="mapping-validation">@ValidationMessage</p> }

            @if (SelectedEntityType == "Division")
            {
                <div class="mapping-current"><span>Current mapped values</span><strong>@SelectedDivision.Name</strong><em>Mapped value: @SelectedDivision.MappedValue · Wards: @SelectedDivision.Wards · Status: @SelectedDivision.Status</em><em>@SelectedDivision.SourceNote</em></div>
                <label>Division name<input value="@SelectedDivision.Name" readonly /></label>
                <label>Mapped value<select @bind="DivisionMappedValue">@foreach (var option in DivisionOptions){<option>@option</option>}</select></label>
                <div class="mapping-field-grid"><label>Number of wards<input value="@SelectedDivision.Wards" readonly /></label><label>Status<input value="@SelectedDivision.Status" readonly /></label></div>
                <p class="mapping-admin-note inline">Division values are maintained as portal mapping values. Source-system alignment remains to be confirmed.</p>
                <label class="mapping-reason-field">Reason for division mapping change<textarea rows="3" @bind="DivisionReason"></textarea></label>
                <button type="button" class="bm-primary" @onclick="UpdateDivision">Update mapping</button>
            }
            else if (SelectedEntityType == "Ward")
            {
                <div class="mapping-current"><span>Current mapped values</span><strong>@SelectedWard.Code · @SelectedWard.Name</strong><em>@SelectedWard.Type / @SelectedWard.Group / @SelectedWard.SpecialistType · @SelectedWard.TotalPhysicalBeds physical beds · @SelectedWard.OpenSourceStatusCount open/source status</em></div>
                <div class="mapping-field-grid"><label>Ward ID<input value="@SelectedWard.Id" readonly /></label><label>Ward code<input value="@SelectedWard.Code" readonly /></label></div>
                <label>Ward name<input value="@SelectedWard.Name" readonly /></label>
                <label>Division<select @bind="WardDivision">@foreach (var option in DivisionOptions){<option>@option</option>}</select></label>
                <label>Admitting consultant<input @bind="WardConsultant" /></label>
                <label class="mapping-toggle"><input type="checkbox" @bind="WardActive" /> Active</label>
                <div class="mapping-field-grid"><label>Ward type<select @bind="WardType">@foreach (var option in WardTypes){<option>@option</option>}</select></label><label>Ward group<select @bind="WardGroup">@foreach (var option in WardGroups){<option>@option</option>}</select></label></div>
                <label>Specialist type<select @bind="WardSpecialistType">@foreach (var option in SpecialistTypes){<option>@option</option>}</select></label>
                <p class="mapping-admin-note inline">Ward mapping describes the ward’s intended clinical grouping. Day-to-day bed availability is managed operationally.</p>
                <label class="mapping-reason-field">Reason for ward mapping change<textarea rows="3" @bind="WardReason"></textarea></label>
                <button type="button" class="bm-primary" @onclick="UpdateWard">Update mapping</button>
            }
            else
            {
                var selectedWard = GetWardForBed(SelectedBed);
                <div class="mapping-current"><span>Current mapped values</span><strong>@SelectedBed.Name</strong><em>@selectedWard.Name · @selectedWard.Division / @selectedWard.Type / @selectedWard.Group / @selectedWard.SpecialistType</em><em>Status from HBCIS: @SelectedBed.HbcisStatus · Operational status context only: @SelectedBed.OperationalStatus</em></div>
                <p class="mapping-admin-note inline">Beds and temporary spaces must be mapped into a ward/bay before they can be used for patient assignment.</p>
                <section class="mapping-detail-section"><h4>Source context / read-only values</h4><div class="mapping-field-grid"><label>District / HHS<input value="@District" readonly /></label><label>Facility name<input value="@FacilityName" readonly /></label><label>Facility code<input value="@FacilityCode" readonly /></label><label>Facility<input value="@Facility" readonly /></label><label>Ward ID<input value="@selectedWard.Id" readonly /></label><label>Ward code<input value="@selectedWard.Code" readonly /></label><label>Ward name<input value="@selectedWard.Name" readonly /></label><label>Extract date/time<input value="@ExtractDateTime" readonly /></label></div></section>
                <section class="mapping-detail-section"><h4>Editable mapping fields</h4><div class="mapping-field-grid"><label>Division<select @bind="WardDivision">@foreach (var option in DivisionOptions){<option>@option</option>}</select></label><label>Ward type<select @bind="WardType">@foreach (var option in WardTypes){<option>@option</option>}</select></label><label>Ward group<select @bind="WardGroup">@foreach (var option in WardGroups){<option>@option</option>}</select></label><label>Ward specialist type<select @bind="WardSpecialistType">@foreach (var option in SpecialistTypes){<option>@option</option>}</select></label><label>Bed label / bed mapping<input @bind="BedLabel" /></label><label>Bed type<select @bind="BedType">@foreach (var option in BedTypes){<option>@option</option>}</select></label></div><fieldset class="mapping-attributes"><legend>Bed attributes</legend>@foreach (var option in BedAttributes){<label><input type="checkbox" checked="@BedSelectedAttributes.Contains(option)" @onchange="args => ToggleBedAttribute(option, args)" /> @option</label>}</fieldset></section>
                <section class="mapping-detail-section"><h4>Status context</h4><div class="mapping-field-grid"><label>Status from HBCIS<input value="@SelectedBed.HbcisStatus" readonly /></label><label class="mapping-context-field">Operational status context only<input value="@SelectedBed.OperationalStatus" readonly /></label><label>Open Beds<input value="@selectedWard.OpenSourceStatusCount" readonly /></label><label>Total Capacity<input value="@selectedWard.TotalPhysicalBeds" readonly /></label><label>UpdatedBy<input value="@SelectedBed.UpdatedBy" readonly /></label><label>LastUpdatedAt<input value="@SelectedBed.LastUpdatedAt" readonly /></label></div></section>
                <label class="mapping-reason-field">Reason for change<textarea rows="3" @bind="BedReason"></textarea></label>
                <div class="mapping-detail-actions"><button type="button" class="bm-primary" @onclick="UpdateBed">Update mapping</button></div>
            }
        </aside>
    </div>
</section>

@code {
    private string ConfirmationMessage = string.Empty;
    private string ValidationMessage = string.Empty;
    private string SelectedEntityType = "Division";
    private string SelectedEntityName => SelectedEntityType switch { "Ward" => SelectedWard.Name, "Bed" => SelectedBed.Name, _ => SelectedDivision.Name };
    private readonly string[] DivisionOptions = ["Critical Care", "Emergency and Acute Care", "Medical Services", "Surgical Services", "Mental Health", "Community and Ambulatory"];
    private readonly string[] WardTypes = ["Inpatient", "Short Stay", "Critical Care", "Mental Health", "Emergency", "Ambulatory"];
    private readonly string[] WardGroups = ["Medical", "Surgical", "Critical Care", "Emergency", "Mental Health", "Other"];
    private readonly string[] SpecialistTypes = ["General", "Paediatric", "Oncology", "Cardiac", "Renal", "Respiratory", "Neurology", "Orthopaedic", "Other"];
    private readonly string[] BedTypes = ["Standard", "Single room", "Shared room", "Isolation", "Critical care", "Mental health", "Treatment space", "Cot", "Carer bed", "Surge space", "Temporary bay"];
    private const string District = "Children’s Health Queensland HHS";
    private const string FacilityName = "Queensland Children’s Hospital";
    private const string Facility = "QCH";
    private const string FacilityCode = "QCH";
    private const string ExtractDateTime = "23 Jan 2026 09:00";
    private readonly string[] BedAttributes = ["Positive pressure", "Negative pressure", "Standard isolation", "Temporary respiratory isolation", "Bariatric", "Hard-wired telemetry", "Haemodialysis", "Care-by-parent", "Infection control", "Specialist equipment", "Paediatric capable"];
    private List<DivisionRow> Divisions = [new("Critical Care", "Critical Care", 1, "Mapped", "Portal category for critical care wards."), new("Medical", "Medical Services", 1, "Mapped", "Portal category mapped for medical services."), new("Surgical", "Surgical Services", 1, "Review due", "Portal category requiring review."), new("Emergency and Acute Care", "Emergency and Acute Care", 1, "Mapped", "Portal category mapped for ED and acute care.")];
    private List<WardRow> Wards = [new("W-PICU", "PICU", "PICU", "Critical Care", "Dr Lee", true, "Critical Care", "Critical Care", "Paediatric", 2, 2), new("W-9A", "9A", "9A Medical", "Medical", "Dr Patel", true, "Inpatient", "Medical", "Respiratory", 2, 2), new("W-8A", "8A", "8A Surgical", "Surgical", "Dr Nguyen", true, "Inpatient", "Surgical", "Orthopaedic", 2, 2), new("W-EDSS", "EDSS", "ED Short Stay", "Emergency and Acute Care", "Dr Smith", true, "Short Stay", "Emergency", "General", 2, 1)];
    private List<BedRow> Beds = [new("B-PICU-01", "Bed 01", "PICU", "Critical care", ["Hard-wired telemetry", "Paediatric capable"], "Active", "Open", "Mapping Admin", "23 Jan 2026 09:10"), new("B-PICU-02", "Bed 02", "PICU", "Isolation", ["Negative pressure", "Infection control", "Paediatric capable"], "Active", "Cleaning", "Mapping Admin", "23 Jan 2026 09:12"), new("B-9A-01", "Bed 01", "9A Medical", "Single room", ["Haemodialysis", "Paediatric capable"], "Active", "Open", "Mapping Admin", "23 Jan 2026 09:15"), new("B-9A-02", "Bed 02", "9A Medical", "Shared room", ["Care-by-parent", "Paediatric capable"], "Active", "Open", "Mapping Admin", "23 Jan 2026 09:16"), new("B-8A-01", "Bed 01", "8A Surgical", "Standard", ["Care-by-parent", "Paediatric capable"], "Active", "Open", "Mapping Admin", "23 Jan 2026 09:18"), new("B-8A-02", "Bed 02", "8A Surgical", "Isolation", ["Negative pressure", "Infection control", "Paediatric capable"], "Active", "Open", "Mapping Admin", "23 Jan 2026 09:19"), new("B-EDSS-01", "Bed 01", "ED Short Stay", "Treatment space", ["Paediatric capable"], "Active", "Open", "Mapping Admin", "23 Jan 2026 09:20"), new("B-EDSS-02", "Temp Bay 02", "ED Short Stay", "Temporary bay", ["Temporary respiratory isolation", "Paediatric capable"], "Active", "Nurse hold", "Mapping Admin", "23 Jan 2026 09:21")];
    private DivisionRow SelectedDivision = default!; private WardRow SelectedWard = default!; private BedRow SelectedBed = default!;
    private string DivisionMappedValue = string.Empty, DivisionReason = string.Empty, WardDivision = string.Empty, WardConsultant = string.Empty, WardType = string.Empty, WardGroup = string.Empty, WardSpecialistType = string.Empty, WardReason = string.Empty, BedLabel = string.Empty, BedAssignedWard = string.Empty, BedType = "Standard", BedReason = string.Empty; private bool WardActive = true;
    private List<string> BedSelectedAttributes = []; private List<ChangeRow> RecentChanges = [];
    protected override void OnInitialized(){ SelectedDivision=Divisions[0]; SelectedWard=Wards[0]; SelectBed(Beds[0]); }
    private bool IsSelected(DivisionRow row) => SelectedEntityType == "Division" && SelectedDivision == row; private bool IsSelected(WardRow row) => SelectedEntityType == "Ward" && SelectedWard == row; private bool IsSelected(BedRow row) => SelectedEntityType == "Bed" && SelectedBed == row;
    private void SelectDivision(DivisionRow row){ SelectedEntityType="Division"; SelectedDivision=row; DivisionMappedValue=row.MappedValue; DivisionReason=ValidationMessage=ConfirmationMessage=string.Empty; }
    private void SelectWard(WardRow row){ SelectedEntityType="Ward"; SelectedWard=row; WardDivision=row.Division; WardConsultant=row.Consultant; WardType=row.Type; WardGroup=row.Group; WardSpecialistType=row.SpecialistType; WardActive=row.Active; WardReason=ValidationMessage=ConfirmationMessage=string.Empty; }
    private void SelectBed(BedRow row){ SelectedEntityType="Bed"; SelectedBed=row; BedLabel=row.Name; BedAssignedWard=row.Ward; BedType=row.Type; var ward = GetWardForBed(row); WardDivision=ward.Division; WardType=ward.Type; WardGroup=ward.Group; WardSpecialistType=ward.SpecialistType; BedSelectedAttributes=[..row.Attributes]; BedReason=ValidationMessage=ConfirmationMessage=string.Empty; }
    private void UpdateDivision(){ if (RequireReason(DivisionReason)) return; AddChange(SelectedDivision.Name, "Mapped value", SelectedDivision.MappedValue, DivisionMappedValue, DivisionReason); SelectedDivision.MappedValue=DivisionMappedValue; DivisionReason=""; ConfirmationMessage="Division mapping update recorded for prototype review."; }
    private void UpdateWard(){ if (RequireReason(WardReason)) return; var previous=$"Division: {SelectedWard.Division} / Consultant: {SelectedWard.Consultant} / {SelectedWard.Type} / {SelectedWard.Group} / {SelectedWard.SpecialistType} / Active: {(SelectedWard.Active ? "Yes" : "No")}"; var next=$"Division: {WardDivision} / Consultant: {WardConsultant} / {WardType} / {WardGroup} / {WardSpecialistType} / Active: {(WardActive ? "Yes" : "No")}"; AddChange(SelectedWard.Name, "Ward mapping fields", previous, next, WardReason); SelectedWard.Division=WardDivision; SelectedWard.Consultant=WardConsultant; SelectedWard.Type=WardType; SelectedWard.Group=WardGroup; SelectedWard.SpecialistType=WardSpecialistType; SelectedWard.Active=WardActive; WardReason=""; ConfirmationMessage="Ward mapping update recorded for prototype review."; }
    private void UpdateBed(){ if (RequireReason(BedReason)) return; var previous=$"Label: {SelectedBed.Name} / Ward: {SelectedBed.Ward} / {GetWardForBed(SelectedBed).Division} / {GetWardForBed(SelectedBed).Type} / {GetWardForBed(SelectedBed).Group} / {GetWardForBed(SelectedBed).SpecialistType} / {SelectedBed.Type} / {FormatAttributes(SelectedBed.Attributes)}"; var next=$"Label: {BedLabel} / Ward: {BedAssignedWard} / {WardDivision} / {WardType} / {WardGroup} / {WardSpecialistType} / {BedType} / {FormatAttributes(BedSelectedAttributes)}"; AddChange(SelectedBed.Name, "Bed mapping fields", previous, next, BedReason); SelectedBed.Name=BedLabel; SelectedBed.Ward=BedAssignedWard; SelectedBed.Type=BedType; var targetWard = Wards.FirstOrDefault(w => w.Name == BedAssignedWard); if (targetWard is not null) { targetWard.Division=WardDivision; targetWard.Type=WardType; targetWard.Group=WardGroup; targetWard.SpecialistType=WardSpecialistType; } SelectedBed.Attributes=[..BedSelectedAttributes]; BedReason=""; ConfirmationMessage="Bed mapping update recorded for prototype review."; }
    private bool RequireReason(string reason){ if (!string.IsNullOrWhiteSpace(reason)){ ValidationMessage=""; return false; } ValidationMessage=$"Reason for {SelectedEntityType.ToLowerInvariant()} mapping change is required before update."; ConfirmationMessage=""; return true; }
    private void ToggleBedAttribute(string option, ChangeEventArgs args){ if (args.Value is bool selected && selected && !BedSelectedAttributes.Contains(option)) BedSelectedAttributes.Add(option); else BedSelectedAttributes.Remove(option); }
    private WardRow GetWardForBed(BedRow bed) => Wards.FirstOrDefault(ward => ward.Name == bed.Ward) ?? Wards[0];
    private static string FormatAttributes(IEnumerable<string> attributes) => attributes.Any() ? string.Join(", ", attributes) : "No attributes selected";
    private void AddChange(string entity, string fieldChanged, string previous, string next, string reason) => RecentChanges.Insert(0, new(entity, fieldChanged, previous, next, reason, "Current Admin User", DateTime.Now.ToString("dd MMM yyyy HH:mm")));
    private sealed class DivisionRow { public DivisionRow(string name, string mappedValue, int wards, string status, string sourceNote) => (Name, MappedValue, Wards, Status, SourceNote) = (name, mappedValue, wards, status, sourceNote); public string Name { get; } public string MappedValue { get; set; } public int Wards { get; } public string Status { get; } public string SourceNote { get; } }
    private sealed class WardRow { public WardRow(string id, string code, string name, string division, string consultant, bool active, string type, string group, string specialistType, int totalPhysicalBeds, int openSourceStatusCount) => (Id, Code, Name, Division, Consultant, Active, Type, Group, SpecialistType, TotalPhysicalBeds, OpenSourceStatusCount) = (id, code, name, division, consultant, active, type, group, specialistType, totalPhysicalBeds, openSourceStatusCount); public string Id { get; } public string Code { get; } public string Name { get; } public string Division { get; set; } public string Consultant { get; set; } public bool Active { get; set; } public string Type { get; set; } public string Group { get; set; } public string SpecialistType { get; set; } public int TotalPhysicalBeds { get; } public int OpenSourceStatusCount { get; } }
    private sealed class BedRow { public BedRow(string id, string name, string ward, string type, List<string> attributes, string hbcisStatus, string operationalStatus, string updatedBy, string lastUpdatedAt) => (Id, Name, Ward, Type, Attributes, HbcisStatus, OperationalStatus, UpdatedBy, LastUpdatedAt) = (id, name, ward, type, attributes, hbcisStatus, operationalStatus, updatedBy, lastUpdatedAt); public string Id { get; } public string Name { get; set; } public string Ward { get; set; } public string Type { get; set; } public List<string> Attributes { get; set; } public string HbcisStatus { get; } public string OperationalStatus { get; } public string UpdatedBy { get; } public string LastUpdatedAt { get; } }
    private sealed record ChangeRow(string Entity, string FieldChanged, string PreviousValue, string NewValue, string Reason, string ChangedBy, string ChangedAt);
}
