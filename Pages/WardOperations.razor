@page "/ward-operations"
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using QHPFH_ConceptPrototype.Components.Shared
@inject NavigationManager Navigation

<section class="page-shell-card bed-mgmt-page ward-ops ward-view-page" @onclick="CloseKpiInfo">
    <header>
        <h2>Ward Operations</h2>
    </header>

    <div class="bm-view-row">
        <button class="bm-ghost version @(WardVersion == "V1" ? "active" : null)" @onclick='() => WardVersion = "V1"'>R2.1 Foundation</button>
        <button class="bm-ghost version @(WardVersion == "V2" ? "active" : null)" @onclick='() => WardVersion = "V2"'>V3 Future Whiteboard Prototype</button>
    </div>

    <p class="ward-scope-note">Ward Operations is the ward-level operational workspace for beds, patients, room types, admissions, discharges and local ward actions. R2.1 foundation does not include full allocation or unrestricted drag-and-drop.</p>

    @if (WardVersion == "V1")
    {
        <section class="bm-capacity-banner red">
            <strong>HOSPITAL CAPACITY STATUS: RED</strong>
            <span>High demand across ED and inpatient flow. Prioritise confirmed discharges before 11:00. Escalate blocked beds to NUM.</span>
        </section>

        <section class="bm-overview-cards ward-summary-strip">
            <SituationalKpiTile Title="Total Physical Beds" Value="24" Subtitle="All physical beds in this ward." IconName="open-bed-default" ColorClass="kpi-blue" InfoText="All physical beds configured in this ward." IsInfoOpen='@(OpenWardKpiInfo == "Total Physical Beds")' OnInfoClick='() => ToggleWardKpiInfo("Total Physical Beds")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Closed Beds" Value="3" Subtitle="Capacity not currently operational." IconName="cleaning-default" ColorClass="kpi-orange" InfoText="Closed beds are physical bed spaces not currently operational and are tracked separately from pending cleaning or maintenance." IsInfoOpen='@(OpenWardKpiInfo == "Closed Beds")' OnInfoClick='() => ToggleWardKpiInfo("Closed Beds")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Open Beds" Value="20" Subtitle="Open for operational use today; not the same as available." IconName="open-bed-green" ColorClass="kpi-green" InfoText="Open beds are operational bed spaces in use today. This is a capacity measure, not a count of currently available empty beds." IsInfoOpen='@(OpenWardKpiInfo == "Open Beds")' OnInfoClick='() => ToggleWardKpiInfo("Open Beds")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Occupied Beds" Value="19" Subtitle="Total occupied" IconName="occupied-bed-default" ColorClass="kpi-gray" TileType="breakdown" BreakdownItems="@WardOccupiedBreakdown" InfoText="Prototype R2.1 breakdown of occupied beds by standard, special, standard mental health and special mental health bed type." IsInfoOpen='@(OpenWardKpiInfo == "Occupied Beds")' OnInfoClick='() => ToggleWardKpiInfo("Occupied Beds")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Expected Admissions" Value="5" Subtitle="Total expected" IconName="open-bed-default" ColorClass="kpi-blue" TileType="breakdown" BreakdownItems="@WardExpectedAdmissionsBreakdown" InfoText="Expected admissions by source for ward awareness only. Bed selection controls remain outside this foundation tile." IsInfoOpen='@(OpenWardKpiInfo == "Expected Admissions")' OnInfoClick='() => ToggleWardKpiInfo("Expected Admissions")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Expected Discharges" Value="—" Subtitle="Coming Soon" IconName="open-bed-default" ColorClass="kpi-green" InfoText="Expected discharge detail is planned for a future phase. This tile does not provide predicted capacity." IsInfoOpen='@(OpenWardKpiInfo == "Expected Discharges")' OnInfoClick='() => ToggleWardKpiInfo("Expected Discharges")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Isolation Beds Available" Value="0" Subtitle="Total available" IconName="isolation-bed-default" ColorClass="kpi-blue" TileType="breakdown" BreakdownItems="@WardIsolationBreakdown" InfoText="Prototype isolation availability by type. These values do not imply that every isolation type is live source-system data." IsInfoOpen='@(OpenWardKpiInfo == "Isolation Beds Available")' OnInfoClick='() => ToggleWardKpiInfo("Isolation Beds Available")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Specialist Beds Available" Value="2" Subtitle="Total available" IconName="open-bed-default" ColorClass="kpi-blue" TileType="breakdown" BreakdownItems="@WardSpecialistBreakdown" InfoText="Prototype specialist bed availability for bariatric, hard-wired telemetry and haemodialysis-enabled bed spaces." IsInfoOpen='@(OpenWardKpiInfo == "Specialist Beds Available")' OnInfoClick='() => ToggleWardKpiInfo("Specialist Beds Available")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Outliers" Value="—" Subtitle="Coming Soon" IconName="occupied-bed-default" ColorClass="kpi-gray" InfoText="Outlier visibility is planned for a future phase; no outlier workflow is included in this foundation tile." IsInfoOpen='@(OpenWardKpiInfo == "Outliers")' OnInfoClick='() => ToggleWardKpiInfo("Outliers")' AdditionalClasses="ward-kpi-card" />
            <SituationalKpiTile Title="Average Length of Stay" Value="—" Subtitle="Coming Soon" IconName="open-bed-default" ColorClass="kpi-gray" InfoText="Average Length of Stay reporting is planned for a future phase; no ALOS workflow is included in this foundation tile." IsInfoOpen='@(OpenWardKpiInfo == "Average Length of Stay")' OnInfoClick='() => ToggleWardKpiInfo("Average Length of Stay")' AdditionalClasses="ward-kpi-card" />
        </section>

        <section class="ward-incoming-compact" aria-labelledby="ward-incoming-heading">
            <div class="ward-incoming-head">
                <div>
                    <h4 id="ward-incoming-heading">Incoming Admissions</h4>
                    <p>Expected arrivals by source for ward awareness.</p>
                </div>
                <button type="button" class="bm-link-compact">View incoming details</button>
            </div>

            <div class="bm-allocation-tabs ward-source-tabs" aria-label="Incoming admission sources">
                @foreach (var tab in IncomingTabs)
                {
                    <button type="button" class="@(IncomingTab == tab ? "active" : null)" @onclick="() => IncomingTab = tab">
                        <span>@tab</span>
                        <strong>@IncomingByTab[tab].Count</strong>
                    </button>
                }
            </div>

            <div class="ward-incoming-preview" aria-label="Selected source preview">
                @if (IncomingByTab[IncomingTab].Any())
                {
                    @foreach (var card in IncomingByTab[IncomingTab].Take(3))
                    {
                        <article class="ward-incoming-row">
                            <div>
                                <strong>@card.Code</strong>
                                <span>@card.Name</span>
                            </div>
                            <span>@card.Source</span>
                            <span>@card.Meta</span>
                            <span class="bm-priority">@card.Status</span>
                            <p>@card.Reason</p>
                        </article>
                    }
                }
                else
                {
                    <p class="ward-incoming-empty">No expected arrivals for @IncomingTab.</p>
                }
            </div>
        </section>

        <section class="bm-ward-table-wrap">
            <table class="bm-ward-table">
                <thead>
                    <tr>
                        <th>Bed</th>
                        <th>Bed status</th>
                        <th>Patient</th>
                        <th>Full name</th>
                        <th>MRN</th>
                        <th>Date of birth</th>
                        <th>Age</th>
                        <th>Sex</th>
                        <th>Admitting doctor</th>
                        <th>Doctor name</th>
                        <th>Doctor specialty</th>
                        <th>Allergies &amp; alerts</th>
                        <th>Diet</th>
                        <th class="actions-col">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var bed in BedRows)
                    {
                        <tr class="state-@bed.StatusClass">
                            <td>
                                <div class="ward-bed-cell room-@bed.RoomTypeClass">
                                    <strong>@bed.BedLabel</strong>
                                    <span>@bed.RoomType</span>
                                </div>
                            </td>

                            <td>
                                <div class="bm-status-pill">
                                    <MudIcon Icon="@StatusIcon(bed.Status)" Size="Size.Small" />
                                    @bed.Status
                                </div>
                            </td>

                            <td>@(bed.HasPatient ? "Current patient" : "No patient")</td>
                            <td>@(bed.HasPatient ? bed.PatientName : "—")</td>
                            <td>@(bed.HasPatient ? bed.Mrn : "—")</td>
                            <td>@(bed.HasPatient ? bed.DateOfBirth : "—")</td>
                            <td>@(bed.HasPatient ? bed.Age : "—")</td>
                            <td>@(bed.HasPatient ? bed.Sex : "—")</td>
                            <td>@(bed.HasPatient ? bed.AdmittingDoctor : "—")</td>
                            <td>@(bed.HasPatient ? bed.DoctorName : "—")</td>
                            <td>@(bed.HasPatient ? bed.DoctorSpecialty : "—")</td>
                            <td>@bed.Allergies</td>
                            <td>@bed.Diet</td>

                            <td>
                                <button type="button" class="ward-transfer-action" title="Request Internal Transfer" @onclick="() => OpenTransferRequest(bed)" disabled="@(!bed.HasPatient)">
                                    Request transfer
                                </button>
                                @if (PendingTransferRequests.Contains(bed.BedLabel))
                                {
                                    <span class="ward-transfer-pending">Pending bed manager review</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <footer>Showing 1–24 of 24 beds</footer>
        </section>

        @if (SelectedTransferBed is not null)
        {
            <section class="ward-transfer-panel" aria-label="Request Internal Transfer">
                <div class="ward-transfer-panel-card">
                    <header>
                        <div>
                            <p class="utility-kicker">Prototype-safe ward request</p>
                            <h3>Request Internal Transfer</h3>
                        </div>
                        <button type="button" class="oncall-close" aria-label="Close request" @onclick="CloseTransferRequest">×</button>
                    </header>

                    @if (!string.IsNullOrWhiteSpace(TransferConfirmation))
                    {
                        <div class="ward-transfer-confirmation">@TransferConfirmation</div>
                    }

                    <p class="ward-transfer-safety">This request does not move the patient, assign a bed, or update formal bed status. It records a review request for the bed manager only.</p>

                    <div class="ward-transfer-context">
                        <div><span>Patient</span><strong>@SelectedTransferBed.PatientName</strong></div>
                        <div><span>MRN</span><strong>@SelectedTransferBed.Mrn</strong></div>
                        <div><span>Current bed</span><strong>@SelectedTransferBed.BedLabel</strong></div>
                        <div><span>Current ward</span><strong>Ward Operations</strong></div>
                    </div>

                    <div class="ward-transfer-form">
                        <label>Requested destination
                            <select @bind="TransferDestination">
                                @foreach (var option in TransferDestinations)
                                {
                                    <option>@option</option>
                                }
                            </select>
                        </label>
                        <label>Reason
                            <select @bind="TransferReason">
                                @foreach (var option in TransferReasons)
                                {
                                    <option>@option</option>
                                }
                            </select>
                        </label>
                        <label>Priority
                            <select @bind="TransferPriority">
                                @foreach (var option in TransferPriorities)
                                {
                                    <option>@option</option>
                                }
                            </select>
                        </label>
                        <label>Notes
                            <textarea rows="3" placeholder="Add review context for the bed manager" @bind="TransferNotes"></textarea>
                        </label>
                        <div><span>Requested by</span><strong>Ward user</strong></div>
                        <div><span>Submitted time</span><strong>@TransferSubmittedTime</strong></div>
                    </div>

                    <footer>
                        <button type="button" class="standard-btn" @onclick="CloseTransferRequest">Cancel</button>
                        <button type="button" class="standard-btn selected" @onclick="SubmitTransferRequest">Request submitted for review</button>
                    </footer>
                </div>
            </section>
        }
    }
    else
    {
        <section class="bm-capacity-banner red">
            <strong>FUTURE WHITEBOARD PROTOTYPE</strong>
            <span>Future-state only — not R2.1 foundation. Prototype drag-and-drop whiteboard interactions are preserved for exploration only.</span>
        </section>

        <div class="bm-main-grid">
            <section class="bm-list-panel">
                <section class="bm-ward-table-wrap">
                    <table class="bm-ward-table">
                        <thead>
                            <tr>
                                <th>Bed</th>
                                <th>Status</th>
                                <th>Patient</th>
                                <th>Team</th>
                                <th>EDD</th>
                                <th>Waiting For</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var bed in V2BedRows.Take(10))
                            {
                                <tr class="state-@bed.StatusClass"
                                    draggable="true"
                                    @ondragstart="() => StartDragBedForAction(bed)"
                                    @ondragover="AllowDrop"
                                    @ondragover:preventDefault="true"
                                    @ondrop="() => DropPatientToBed(bed)">
                                    <td><strong>@bed.BedLabel</strong></td>

                                    <td>
                                        <div class="bm-status-pill">
                                            <MudIcon Icon="@StatusIcon(bed.Status)" Size="Size.Small" />
                                            @bed.Status
                                        </div>
                                    </td>

                                    <td>@(bed.HasPatient ? bed.PatientName : "—")</td>
                                    <td>@bed.Team</td>
                                    <td>@bed.Edd</td>
                                    <td>@bed.WaitingFor</td>

                                    <td>
                                        <div class="bm-inline-actions">
                                            @foreach (var action in V2ActionDefs)
                                            {
                                                <button type="button" title="@action.Label" @onclick="() => ApplyBedAction(bed, action.Key)">
                                                    <MudIcon Icon="@action.Icon" Size="Size.Small" />
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </section>
            </section>

            <aside class="bm-right-panel">
                <article>
                    <h4>Prototype Incoming</h4>

                    <div class="bm-allocation-tabs">
                        @foreach (var tab in V2IncomingTabs)
                        {
                            <button type="button" class="@(V2IncomingTab == tab ? "active" : null)" @onclick="() => V2IncomingTab = tab">
                                @tab (@V2IncomingByTab[tab].Count)
                            </button>
                        }
                    </div>

                    <div class="bm-cards bm-cards-compact">
                        @foreach (var card in V2IncomingByTab[V2IncomingTab].Take(4))
                        {
                            <article class="bm-patient-card bm-patient-card-compact" draggable="true" @ondragstart="() => StartDragFromIncoming(card)">
                                <div class="bm-patient-row-top">
                                    <strong>@card.Code · @card.Meta</strong>
                                    <span class="bm-priority">@card.Priority</span>
                                </div>
                                <p class="bm-patient-name">@card.Name</p>
                                <p class="bm-patient-reason">@card.Reason</p>
                            </article>
                        }
                    </div>
                </article>

                <article>
                    <h4>Prototype Quick Actions</h4>

                    <div class="bm-actions">
                        @foreach (var action in V2ActionDefs)
                        {
                            <button type="button"
                                    class="qa-drop @(_hoverAction == action.Key ? "hover" : null)"
                                    @ondragover="() => HoverAction(action.Key)"
                                    @ondragover:preventDefault="true"
                                    @ondragleave="() => _hoverAction = null"
                                    @ondrop="() => DropBedToAction(action.Key)">
                                <MudIcon Icon="@action.Icon" Size="Size.Small" />
                                @action.Label
                            </button>
                        }
                    </div>
                </article>

                <article>
                    <h4>Prototype Drop Zones</h4>

                    <div class="bm-targets">
                        @foreach (var target in V2MoveTargets)
                        {
                            <div class="bm-move-target"
                                 @ondragover="AllowDrop"
                                 @ondragover:preventDefault="true"
                                 @ondrop="() => DropBedToTarget(target)">
                                @target
                            </div>
                        }
                    </div>
                </article>

                <article>
                    <h4>Recent Activity</h4>

                    <ul class="bm-activity">
                        @foreach (var item in V2Activity.Take(4))
                        {
                            <li>@item</li>
                        }
                    </ul>
                </article>
            </aside>
        </div>
    }
</section>

@code {
    private string WardVersion { get; set; } = "V1";
    private string IncomingTab { get; set; } = "ED";
    private string V2IncomingTab { get; set; } = "ED";
    private string? OpenWardKpiInfo { get; set; }
    private BedRow? SelectedTransferBed { get; set; }
    private string TransferDestination { get; set; } = "Review by bed manager";
    private string TransferReason { get; set; } = "Clinical flow review";
    private string TransferPriority { get; set; } = "Routine";
    private string TransferNotes { get; set; } = string.Empty;
    private string TransferSubmittedTime { get; set; } = "Not submitted";
    private string TransferConfirmation { get; set; } = string.Empty;
    private readonly HashSet<string> PendingTransferRequests = new();

    private string? _hoverAction;
    private string _dragMode = string.Empty;
    private IncomingCard? _draggedIncoming;
    private BedRow? _draggedBed;

    private static readonly string[] IncomingTabs = { "ED", "IHT", "Add-On", "Ward Transfer", "Elective / Planned" };
    private static readonly string[] V2IncomingTabs = { "ED", "IHT", "OPD", "Other" };
    private static readonly string[] TransferDestinations = { "8A Surgical", "11B Medical", "Logan Hospital", "QCH 9A", "Review by bed manager" };
    private static readonly string[] TransferReasons = { "Cohorting / room suitability", "Isolation requirement", "Specialist bed need", "Family / care-by-parent room need", "Clinical flow review", "Other" };
    private static readonly string[] TransferPriorities = { "Routine", "Today", "Urgent review" };

    private readonly Dictionary<string, List<IncomingCard>> IncomingByTab = new()
    {
        ["ED"] = new(),
        ["IHT"] = new(),
        ["Add-On"] = new(),
        ["Ward Transfer"] = new(),
        ["Elective / Planned"] = new()
    };

    private readonly Dictionary<string, List<IncomingCard>> V2IncomingByTab = new()
    {
        ["ED"] = new(),
        ["IHT"] = new(),
        ["OPD"] = new(),
        ["Other"] = new()
    };

    private readonly List<string> V2MoveTargets = new()
    {
        "IHT Returns Queue",
        "Pending Transfer",
        "Temporary Hold",
        "Discharge Pending"
    };

    private readonly List<string> V2Activity = new()
    {
        "12:20 Bed 3 marked Cleaning",
        "12:25 Bed 3 marked Ready",
        "12:26 Bed 4 blocked due to adjacent behaviour risk",
        "12:27 Maintenance requested for Bed 8"
    };

    private readonly (string Key, string Label, string Icon)[] V2ActionDefs =
    {
        ("ready", "Mark Ready", Icons.Material.Outlined.CheckCircle),
        ("cleaning", "Mark Cleaning", Icons.Material.Outlined.CleaningServices),
        ("block", "Block Bed", Icons.Material.Outlined.Lock),
        ("maintenance", "Request Maintenance", Icons.Material.Outlined.Handyman),
        ("isolation", "Mark As Isolation", Icons.Material.Outlined.Shield),
        ("note", "Add Operational Note", Icons.Material.Outlined.StickyNote2)
    };

    private List<BedRow> BedRows = new();
    private List<BedRow> V2BedRows = new();
    private static readonly IReadOnlyList<SituationalKpiTile.KpiBreakdownItem> WardOccupiedBreakdown = new[]
    {
        new SituationalKpiTile.KpiBreakdownItem("Standard", "15"),
        new SituationalKpiTile.KpiBreakdownItem("Special", "2"),
        new SituationalKpiTile.KpiBreakdownItem("Standard MH", "1"),
        new SituationalKpiTile.KpiBreakdownItem("Special MH", "1")
    };

    private static readonly IReadOnlyList<SituationalKpiTile.KpiBreakdownItem> WardExpectedAdmissionsBreakdown = new[]
    {
        new SituationalKpiTile.KpiBreakdownItem("ED", "3"),
        new SituationalKpiTile.KpiBreakdownItem("IHT", "1"),
        new SituationalKpiTile.KpiBreakdownItem("Add-On", "1"),
        new SituationalKpiTile.KpiBreakdownItem("Ward Transfer", "0"),
        new SituationalKpiTile.KpiBreakdownItem("Elective / Planned", "0")
    };

    private static readonly IReadOnlyList<SituationalKpiTile.KpiBreakdownItem> WardIsolationBreakdown = new[]
    {
        new SituationalKpiTile.KpiBreakdownItem("Positive pressure", "0"),
        new SituationalKpiTile.KpiBreakdownItem("Negative pressure", "0"),
        new SituationalKpiTile.KpiBreakdownItem("Standard isolation", "0"),
        new SituationalKpiTile.KpiBreakdownItem("Temporary respiratory isolation", "0")
    };

    private static readonly IReadOnlyList<SituationalKpiTile.KpiBreakdownItem> WardSpecialistBreakdown = new[]
    {
        new SituationalKpiTile.KpiBreakdownItem("Bariatric", "1"),
        new SituationalKpiTile.KpiBreakdownItem("Hard-Wired Telemetry", "1"),
        new SituationalKpiTile.KpiBreakdownItem("Haemodialysis", "0")
    };

    private void ToggleWardKpiInfo(string title) => OpenWardKpiInfo = OpenWardKpiInfo == title ? null : title;
    private void CloseKpiInfo() => OpenWardKpiInfo = null;

    private void OpenTransferRequest(BedRow bed)
    {
        if (!bed.HasPatient)
        {
            return;
        }

        SelectedTransferBed = bed;
        TransferDestination = "Review by bed manager";
        TransferReason = "Clinical flow review";
        TransferPriority = "Routine";
        TransferNotes = string.Empty;
        TransferSubmittedTime = "Not submitted";
        TransferConfirmation = string.Empty;
    }

    private void SubmitTransferRequest()
    {
        if (SelectedTransferBed is null)
        {
            return;
        }

        PendingTransferRequests.Add(SelectedTransferBed.BedLabel);
        TransferSubmittedTime = DateTime.Now.ToString("dd MMM yyyy HH:mm");
        TransferConfirmation = "Internal transfer request recorded for prototype review. Pending bed manager review.";
    }

    private void CloseTransferRequest()
    {
        SelectedTransferBed = null;
        TransferConfirmation = string.Empty;
    }

    protected override void OnInitialized()
    {
        BedRows = Enumerable.Range(1, 24).Select(CreateBed).ToList();

        IncomingByTab["ED"] = new()
        {
            new IncomingCard("ED001", "DEMO-PAT-ED-01", "Awaiting bed", "ED", "ETA 10:40", "Post-op monitoring; surgical review requested"),
            new IncomingCard("ED002", "DEMO-PAT-ED-02", "For review", "ED", "ETA 11:10", "Abdominal pain; awaiting senior decision"),
            new IncomingCard("ED003", "DEMO-PAT-ED-03", "Pending confirmation", "ED", "Window 12:00–13:00", "Possible admission; diagnostics pending")
        };

        IncomingByTab["IHT"] = new()
        {
            new IncomingCard("IHT001", "DEMO-PAT-IHT-01", "Expected", "IHT", "ETA 13:30", "Return from tertiary review")
        };

        IncomingByTab["Add-On"] = new()
        {
            new IncomingCard("ADD001", "DEMO-PAT-ADD-01", "Awaiting bed", "Add-On", "Expected PM", "Theatre add-on requiring overnight ward care")
        };

        IncomingByTab["Ward Transfer"] = new();
        IncomingByTab["Elective / Planned"] = new();

        var feed = QHPFH_ConceptPrototype.Data.DemoHubData.BuildPatientAdmissions();
        V2BedRows = Enumerable.Range(1, 48).Select(n => CreateV2Bed(n, feed)).ToList();

        V2IncomingByTab["ED"] = feed.Take(4)
            .Select((p, i) => new IncomingCard(
                $"ED{i + 1:000}",
                $"{p.LastName.ToUpperInvariant()}, {p.FirstName}",
                "Emergency admission",
                "ED",
                $"{DateTime.Now.AddMinutes(20 + i * 10):HH:mm}",
                i == 0 ? "High" : "Medium"))
            .ToList();

        V2IncomingByTab["IHT"] = feed.Skip(20).Take(2)
            .Select((p, i) => new IncomingCard(
                $"IHT{i + 1:000}",
                $"{p.LastName.ToUpperInvariant()}, {p.FirstName}",
                "Inter-hospital transfer",
                "IHT",
                $"{DateTime.Now.AddMinutes(35 + i * 10):HH:mm}",
                "Medium"))
            .ToList();

        V2IncomingByTab["OPD"] = feed.Skip(40).Take(1)
            .Select((p, i) => new IncomingCard(
                $"OPD{i + 1:000}",
                $"{p.LastName.ToUpperInvariant()}, {p.FirstName}",
                "Post procedure",
                "OPD",
                $"{DateTime.Now.AddMinutes(55):HH:mm}",
                "Low"))
            .ToList();
    }

    private static BedRow CreateBed(int n)
    {
        if (n == 20)
        {
            return new("Bed 20", "Open / Ready", string.Empty, string.Empty, "General Surgery", "—", "ED", "27 May", 0, "—", "Regular", 0, "Available");
        }

        if (n == 21)
        {
            return new("Bed 21", "Cleaning", string.Empty, string.Empty, "General Surgery", "—", "Ward", "—", 0, "Housekeeping", "—", 0, "Awaiting clean");
        }

        if (n == 22)
        {
            return new("Bed 22", "Maintenance", string.Empty, string.Empty, "General Surgery", "—", "Ward", "—", 0, "Engineering", "—", 0, "Maintenance review");
        }

        if (n == 23 || n == 24)
        {
            return new($"Bed {n}", "Closed", string.Empty, string.Empty, "General Surgery", "—", "Ward", "—", 0, "—", "—", 0, "Closed operationally");
        }

        var ews = (n % 5) + 1;

        var fictionalNames = new[]
        {
            "Clark Kent","Diana Prince","Bruce Wayne","Peter Parker","Natasha Romanoff","Tony Stark","Leia Organa","Ellen Ripley",
            "Sarah Connor","Marty McFly","Wanda Maximoff","Jean Grey","Hermione Granger","Indiana Jones","Dana Scully","Neo Anderson",
            "Katniss Everdeen","Bruce Banner","Selina Kyle","Luke Skywalker","Arthur Curry","Logan Howlett","Barry Allen","Padme Amidala"
        };
        var patientName = fictionalNames[(n - 1) % fictionalNames.Length];
        var dob = new DateTime(1945 + (n % 45), ((n - 1) % 12) + 1, ((n * 2) % 27) + 1);
        var age = 30 + n % 35;
        var sex = n % 2 == 0 ? "F" : "M";
        var roomType = n % 10 == 0 ? "MH" : n % 8 == 0 ? "Specialist" : n % 6 == 0 ? "Cohorting" : n % 5 == 0 ? "Isolation" : "Standard";
        var doctorName = n % 3 == 0 ? "Dr Priya Shah" : n % 3 == 1 ? "Dr Marcus Lee" : "Dr Aisha Rahman";
        var doctorSpecialty = n % 4 == 0 ? "Orthopaedics" : n % 4 == 1 ? "General Surgery" : n % 4 == 2 ? "Respiratory" : "Geriatric Medicine";

        return new(
            $"Bed {n}",
            "Occupied",
            patientName,
            $"MRN DEMO{n:000} | {age}y | {sex}",
            doctorSpecialty,
            n % 4 == 0 ? "Penicillin" : "NKA",
            n % 3 == 0 ? "IHT" : "ED",
            "26 May",
            20 + (n * 3 % 75),
            "Bloods pending",
            n % 2 == 0 ? "Diabetic" : "Regular",
            ews,
            "Clinical review",
            roomType,
            $"DEMO{n:000}",
            dob.ToString("dd MMM yyyy"),
            age.ToString(),
            sex,
            "Admitting consultant",
            doctorName,
            doctorSpecialty);
    }

    private static void AllowDrop(DragEventArgs _)
    {
    }

    private void HoverAction(string key)
    {
        _hoverAction = key;
    }

    private void StartDragFromIncoming(IncomingCard card)
    {
        _dragMode = "incoming";
        _draggedIncoming = card;
        _draggedBed = null;
    }

    private void StartDragBedForAction(BedRow bed)
    {
        _dragMode = "bed";
        _draggedBed = bed;
        _draggedIncoming = null;
    }

    private void DropPatientToBed(BedRow bed)
    {
        if (_dragMode != "incoming" || _draggedIncoming is null)
        {
            return;
        }

        if (bed.Status != "Open / Ready")
        {
            return;
        }

        bed.AdmitFromIncoming(_draggedIncoming);

        foreach (var list in V2IncomingByTab.Values)
        {
            list.Remove(_draggedIncoming);
        }

        V2Activity.Insert(0, $"{DateTime.Now:HH:mm} {_draggedIncoming.Code} placed into {bed.BedLabel}");

        _draggedIncoming = null;
        _dragMode = string.Empty;
    }

    private void DropBedToAction(string key)
    {
        if (_dragMode != "bed" || _draggedBed is null)
        {
            return;
        }

        ApplyBedAction(_draggedBed, key);

        _draggedBed = null;
        _dragMode = string.Empty;
        _hoverAction = null;
    }

    private void DropBedToTarget(string target)
    {
        if (_draggedBed is null || !_draggedBed.HasPatient)
        {
            return;
        }

        V2IncomingByTab["IHT"].Add(new IncomingCard(
            "IHT-R",
            _draggedBed.PatientName,
            _draggedBed.Team,
            "From ward",
            target,
            "Medium"));

        V2Activity.Insert(0, $"{DateTime.Now:HH:mm} {_draggedBed.BedLabel} moved to {target}");

        _draggedBed.MarkCleaning();

        _draggedBed = null;
        _dragMode = string.Empty;
    }

    private void ApplyBedAction(BedRow bed, string key)
    {
        switch (key)
        {
            case "ready":
                bed.Status = "Open / Ready";
                bed.WaitingFor = "Available";
                if (!bed.HasPatient)
                {
                    bed.ClearPatient();
                }
                V2Activity.Insert(0, $"{DateTime.Now:HH:mm} {bed.BedLabel} marked Ready");
                break;

            case "cleaning":
                bed.MarkCleaning();
                V2Activity.Insert(0, $"{DateTime.Now:HH:mm} {bed.BedLabel} marked Cleaning");
                break;

            case "block":
                bed.Status = "Blocked";
                bed.WaitingFor = "NUM hold";
                V2Activity.Insert(0, $"{DateTime.Now:HH:mm} {bed.BedLabel} blocked");
                break;

            case "maintenance":
                bed.Status = "Maintenance";
                bed.WaitingFor = "Maintenance review";
                V2Activity.Insert(0, $"{DateTime.Now:HH:mm} Maintenance requested for {bed.BedLabel}");
                break;

            case "isolation":
                bed.Status = "Isolation / Specialist";
                bed.WaitingFor = "Isolation review";
                V2Activity.Insert(0, $"{DateTime.Now:HH:mm} {bed.BedLabel} marked Isolation / Specialist");
                break;

            case "note":
                V2Activity.Insert(0, $"{DateTime.Now:HH:mm} Operational note added for {bed.BedLabel}");
                break;
        }
    }

    private static BedRow CreateV2Bed(int n, IReadOnlyList<QHPFH_ConceptPrototype.Models.PatientAdmission> feed)
    {
        if (n == 8)
        {
            return new($"Bed {n}", "Maintenance", string.Empty, string.Empty, "-", "-", "Ward", "-", 0, "-", "-", 0, "Maintenance review");
        }

        if (n == 9)
        {
            return new($"Bed {n}", "Blocked", string.Empty, string.Empty, "-", "-", "Ward", "-", 0, "-", "-", 0, "NUM hold");
        }

        var status = n % 7 == 0 ? "Open / Ready" : n % 6 == 0 ? "Cleaning" : "Occupied";
        var patient = feed[(n * 3) % feed.Count];
        var patientName = status == "Occupied" ? $"{patient.LastName.ToUpperInvariant()}, {patient.FirstName}" : string.Empty;
        var demographics = status == "Occupied" ? $"MRN DEMO{n:000} | {patient.Age}y | {patient.Sex}" : string.Empty;

        return new(
            $"Bed {n}",
            status,
            patientName,
            demographics,
            "General Surgery",
            status == "Occupied" ? "None" : "-",
            "ED",
            "26 May",
            status == "Occupied" ? 30 : 0,
            status == "Occupied" ? "Results pending" : "-",
            "Regular",
            status == "Occupied" ? 2 : 0,
            status == "Open / Ready" ? "Available" : status == "Cleaning" ? "Awaiting cleaning" : "Clinical review");
    }

    private static string StatusIcon(string status)
    {
        return status switch
        {
            "Occupied" => Icons.Material.Outlined.Person,
            "Open / Ready" => Icons.Material.Outlined.CheckCircle,
            "Cleaning" => Icons.Material.Outlined.CleaningServices,
            "Closed" => Icons.Material.Outlined.Lock,
            "Blocked" => Icons.Material.Outlined.Lock,
            "Maintenance" => Icons.Material.Outlined.Handyman,
            "Isolation / Specialist" => Icons.Material.Outlined.Shield,
            _ => Icons.Material.Outlined.Bed
        };
    }

    private sealed class IncomingCard
    {
        public IncomingCard(string code, string name, string status, string source, string meta, string priority)
        {
            Code = code;
            Name = name;
            Status = status;
            Source = source;
            FutureBedLabel = meta;
            FutureBed = meta.StartsWith("Bed ", StringComparison.OrdinalIgnoreCase) ? meta : string.Empty;
            Meta = meta;
            Priority = priority;
            Reason = status;
        }

        public string Code { get; }
        public string Name { get; }
        public string Status { get; }
        public string Source { get; }
        public string Reason { get; }
        public string FutureBedLabel { get; set; }
        public string FutureBed { get; set; }
        public string Meta { get; set; }
        public string Priority { get; set; }
    }

    private sealed class BedRow
    {
        public BedRow(
            string bedLabel,
            string status,
            string patientName,
            string demographics,
            string team,
            string allergies,
            string referral,
            string edd,
            int dischargeProgress,
            string requests,
            string diet,
            int ews,
            string waitingFor,
            string roomType = "Standard",
            string mrn = "",
            string dateOfBirth = "",
            string age = "",
            string sex = "",
            string admittingDoctor = "",
            string doctorName = "",
            string doctorSpecialty = "")
        {
            BedLabel = bedLabel;
            Status = status;
            PatientName = patientName;
            Demographics = demographics;
            Team = team;
            Allergies = allergies;
            Referral = referral;
            Edd = edd;
            DischargeProgress = dischargeProgress;
            Requests = requests;
            Diet = diet;
            Ews = ews;
            WaitingFor = waitingFor;
            RoomType = roomType;
            Mrn = mrn;
            DateOfBirth = dateOfBirth;
            Age = age;
            Sex = sex;
            AdmittingDoctor = admittingDoctor;
            DoctorName = doctorName;
            DoctorSpecialty = doctorSpecialty;
        }

        public string BedLabel { get; }
        public string Status { get; set; }
        public string PatientName { get; set; }
        public string Demographics { get; set; }
        public string Team { get; set; }
        public string Allergies { get; set; }
        public string Referral { get; set; }
        public string Edd { get; set; }
        public int DischargeProgress { get; set; }
        public string Requests { get; set; }
        public string Diet { get; set; }
        public int Ews { get; set; }
        public string WaitingFor { get; set; }
        public string RoomType { get; set; }
        public string Mrn { get; set; }
        public string DateOfBirth { get; set; }
        public string Age { get; set; }
        public string Sex { get; set; }
        public string AdmittingDoctor { get; set; }
        public string DoctorName { get; set; }
        public string DoctorSpecialty { get; set; }
        public bool HasPatient => !string.IsNullOrWhiteSpace(PatientName);
        public string RoomTypeClass => RoomType.ToLowerInvariant().Replace(" ", "-");

        public string StatusClass => Status
            .ToLowerInvariant()
            .Replace(" / ", "-")
            .Replace(" ", "-");

        public void AdmitFromIncoming(IncomingCard card)
        {
            Status = "Occupied";
            PatientName = card.Name;
            Demographics = $"MRN {card.Code} | incoming";
            Mrn = card.Code;
            DateOfBirth = "TBC";
            Age = "TBC";
            Sex = "TBC";
            AdmittingDoctor = "Admitting consultant";
            DoctorName = "TBC";
            DoctorSpecialty = "TBC";
            Referral = card.Source;
            Edd = "TBC";
            Requests = card.Reason;
            Diet = "Regular";
            Ews = 1;
            WaitingFor = "Admission review";
            DischargeProgress = 0;
        }

        public void MarkCleaning()
        {
            Status = "Cleaning";
            ClearPatient();
            WaitingFor = "Awaiting cleaning";
            Requests = "Housekeeping";
            Referral = "Ward";
        }

        public void ClearPatient()
        {
            PatientName = string.Empty;
            Demographics = string.Empty;
            Mrn = string.Empty;
            DateOfBirth = string.Empty;
            Age = string.Empty;
            Sex = string.Empty;
            AdmittingDoctor = string.Empty;
            DoctorName = string.Empty;
            DoctorSpecialty = string.Empty;
            Allergies = "—";
            Referral = "Ward";
            Edd = "—";
            DischargeProgress = 0;
            Requests = "—";
            Diet = "—";
            Ews = 0;
        }
    }
