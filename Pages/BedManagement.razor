@page "/bed-management"
@using QHPFH_ConceptPrototype.Data
@using MudBlazor
@using QHPFH_ConceptPrototype.Components.Shared

<section class="page-shell-card bed-mgmt-page bm-overview-page" @onclick="CloseKpiInfo" @onkeydown="HandleKeydown" tabindex="0">
    @if (IsQchAccess)
    {
        <section class="bm-notification-banner">
            <div class="bm-notification-banner-head">
                <strong>Facility notifications</strong>
                <button type="button" class="bm-ghost bm-mini-btn" @onclick="StartCreateNotification">Create notification</button>
            </div>
            @if (IsCreatingNotification)
            {
                <div class="bm-notification-editor">
                    <input @bind="DraftNotification.Title" placeholder="Title/status" />
                    <textarea @bind="DraftNotification.Message" placeholder="Operational message"></textarea>
                    <select @bind="DraftNotification.Severity">
                        <option value="green">Tier 1 / BAU</option>
                        <option value="amber">Tier 2 / Amber</option>
                        <option value="red">Tier 3 / Extreme</option>
                        <option value="dark">Incident Management</option>
                        <option value="blue">Standard Info</option>
                    </select>
                    <div class="bm-notification-actions"><button type="button" class="bm-ghost bm-mini-btn" @onclick="SaveCreateNotification">Save</button><button type="button" class="bm-ghost bm-mini-btn" @onclick="CancelCreateNotification">Cancel</button></div>
                </div>
            }
            @if (QchNotifications.Count == 0)
            {
                <div class="bm-notification-empty">No active facility notifications</div>
            }
            else
            {
                @foreach (var note in QchNotifications)
                {
                    <div class="bm-notification-row @($"sev-{note.Severity}")">
                        @if (EditingNotificationId == note.Id)
                        {
                            <div class="bm-notification-editor inline">
                                <input @bind="DraftNotification.Title" />
                                <textarea @bind="DraftNotification.Message"></textarea>
                                <select @bind="DraftNotification.Severity">
                                    <option value="green">Tier 1 / BAU</option><option value="amber">Tier 2 / Amber</option><option value="red">Tier 3 / Extreme</option><option value="dark">Incident Management</option><option value="blue">Standard Info</option>
                                </select>
                                <div class="bm-notification-actions"><button type="button" class="bm-ghost bm-mini-btn" @onclick="() => SaveUpdateNotification(note.Id)">Save</button><button type="button" class="bm-ghost bm-mini-btn" @onclick="CancelUpdateNotification">Cancel</button></div>
                            </div>
                        }
                        else
                        {
                            <div class="bm-notification-content"><strong>@note.Title</strong><span>@note.Message</span></div>
                            <div class="bm-notification-actions"><button type="button" class="bm-ghost bm-mini-btn" @onclick="() => StartUpdateNotification(note.Id)">Update</button><button type="button" class="bm-ghost bm-mini-btn" @onclick="() => RemoveNotification(note.Id)">Remove</button></div>
                        }
                    </div>
                }
            }
        </section>
    }

    <section class="bm-filter-row bm-filter-row-compact">
        <div class="bm-filter-group">
            @if (!IsQchAccess)
            {
                <div class="bm-filter"><label>HHS</label><select @bind="SelectedHhs" @bind:after="OnHhsChanged">@foreach (var hhs in HhsOptions){<option value="@hhs">@hhs</option>}</select></div>
                <div class="bm-filter"><label>Facility</label><select @bind="SelectedFacility">@foreach (var facility in FacilityOptions){<option value="@facility">@facility</option>}</select></div>
            }
            <div class="bm-filter"><label>Ward</label><select @bind="SelectedWard">@foreach (var ward in WardOptions){<option value="@ward">@ward</option>}</select></div>
        </div>
        <div class="bm-access-selector">
            <label>Access view</label>
            <select @bind="SelectedAccessView" @bind:after="OnAccessViewChanged">
                <option value="statewide">Statewide</option>
                <option value="qch-bed-manager">QCH Bed Manager</option>
            </select>
        </div>
    </section>

    @if (SelectedVersion == "V2")
    {
        <section class="bm-v2-operational-shell">
            <section class="bm-overview-cards bm-v2-status-row bm-v2-pane @(ShowInsightsPanel ? "is-hidden" : "is-active")">
                @foreach (var kpi in (IsQchAccess ? QchKpis : Kpis))
                {
                    <SituationalKpiTile
                        Title="@kpi.Title"
                        Value="@kpi.Value"
                        Subtitle="@kpi.Subtitle"
                        IconName="@kpi.IconName"
                        ColorClass="@kpi.ColorClass"
                        InfoText="@kpi.InfoText"
                        TileType="@kpi.TileType"
                        ShowInfoIcon="@kpi.ShowInfoIcon"
                        IsInfoOpen="@(OpenKpiInfoTitle == kpi.Title)"
                        OnInfoClick="() => ToggleKpiInfo(kpi.Title)"
                        BreakdownItems="@kpi.BreakdownItems"
                        Tabs="@kpi.Tabs"
                        ActiveTab="@QchActivityView"
                        OnTabChanged="OnQchActivityTabChanged"
                        AdditionalClasses="bm-kpi-card" />
                }
                <button type="button" class="bm-system-insights-trigger" @onclick="() => ShowInsightsPanel = true">
                    <span class="bm-system-insights-count">@ActiveInsights.Count</span>
                    <span>System Insights</span>
                </button>
            </section>
            <section class="bm-insight-panel-drawer bm-v2-pane @(ShowInsightsPanel ? "is-active" : "is-hidden")">
                <div class="bm-insight-inline-row">
                    <button type="button" class="bm-system-insights-trigger" @onclick="() => ShowInsightsPanel = false">
                        <span class="bm-system-insights-count">←</span>
                        <span>Back to System Status</span>
                    </button>
                    <section class="bm-insight-grid actionable">
                        @foreach (var insight in ActiveInsights.Take(10))
                        {
                            <article class="bm-insight-card @insight.SeverityClass @(IsInsightActive(insight.InsightKey) ? "selected" : null)" @onclick='() => ApplyInsightFilter(insight.InsightKey)'>
                                <div class="bm-insight-main">
                                    <div class="bm-insight-icon"><MudIcon Icon="@insight.Icon" Size="Size.Small" /></div>
                                    <div class="bm-insight-text">
                                        <h4>@insight.Title</h4>
                                        <p>@insight.Description</p>
                                        <div class="bm-insight-foot">
                                            <strong>Wards: @insight.Count</strong>
                                            <button type="button" class="bm-insight-action" @onclick:stopPropagation="true" @onclick='() => ApplyInsightFilter(insight.InsightKey)'>@insight.ActionLabel</button>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        }
                    </section>
                </div>
            </section>
        </section>
    }
    else
    {
        <section class="bm-overview-cards">
            @foreach (var kpi in (IsQchAccess ? QchKpis : Kpis))
            {
                <SituationalKpiTile
                    Title="@kpi.Title"
                    Value="@kpi.Value"
                    Subtitle="@kpi.Subtitle"
                    IconName="@kpi.IconName"
                    ColorClass="@kpi.ColorClass"
                    InfoText="@kpi.InfoText"
                    TileType="@kpi.TileType"
                    ShowInfoIcon="@kpi.ShowInfoIcon"
                    IsInfoOpen="@(OpenKpiInfoTitle == kpi.Title)"
                    OnInfoClick="() => ToggleKpiInfo(kpi.Title)"
                    BreakdownItems="@kpi.BreakdownItems"
                    Tabs="@kpi.Tabs"
                    ActiveTab="@QchActivityView"
                    OnTabChanged="OnQchActivityTabChanged"
                    AdditionalClasses="bm-kpi-card" />
            }
        </section>
        <section class="bm-insight-grid actionable">
        @foreach (var insight in ActiveInsights)
        {
            <article class="bm-insight-card @insight.SeverityClass @(IsInsightActive(insight.InsightKey) ? "selected" : null)" @onclick='() => ApplyInsightFilter(insight.InsightKey)'>
                <div class="bm-insight-main">
                    <div class="bm-insight-icon"><MudIcon Icon="@insight.Icon" Size="Size.Small" /></div>
                    <div class="bm-insight-text">
                        <h4>@insight.Title</h4>
                        <p>@insight.Description</p>
                        <div class="bm-insight-foot">
                            <strong>Wards: @insight.Count</strong>
                            <button type="button" class="bm-insight-action" @onclick:stopPropagation="true" @onclick='() => ApplyInsightFilter(insight.InsightKey)'>@insight.ActionLabel</button>
                        </div>
                    </div>
                </div>
            </article>
        }
    </section>
    }

    @if (!string.IsNullOrWhiteSpace(ActiveInsightTitle))
    {
        <section class="bm-active-insight-bar">
            <span>Showing wards: @ActiveInsightTitle (@ActiveInsightWardIds.Count)</span>
            <button type="button" class="bm-ghost" @onclick="ClearInsightFilter">Clear</button>
        </section>
    }


    @if (SelectedVersion == "V2" && IsQchAccess)
    {
        <section class="bm-orchestration-panel">
            <header>
                <div>
                    <h4>Operational Orchestration Panel</h4>
                    <p>Coordinate flow across admissions, transfers, staffing and predicted capacity windows.</p>
                </div>
                <div class="bm-orch-actions">
                    <button type="button" class="bm-ghost">Open Bed Managers Chat</button>
                    <button type="button" class="bm-ghost">On-call &amp; escalation</button>
                </div>
            </header>
            <div class="bm-orch-grid">
                <article>
                    <h5>Forward Look (next 6h)</h5>
                    <ul>
                        @foreach (var insight in GetPredictiveInsights())
                        {
                            <li><span class="bm-pressure-pill @insight.PressureClass">@insight.Window</span> @insight.Message</li>
                        }
                    </ul>
                </article>
                <article>
                    <h5>Staffing Impact</h5>
                    <ul>
                        @foreach (var staffing in GetStaffingImpacts())
                        {
                            <li><strong>@staffing.Ward:</strong> @staffing.Message</li>
                        }
                    </ul>
                </article>
                <article>
                    <h5>Transfer Coordination Queue</h5>
                    <ul>
                        @foreach (var transfer in GetTransferRisks())
                        {
                            <li><strong>@transfer.Ward</strong> — @transfer.Status <em>@transfer.WaitingState</em></li>
                        }
                    </ul>
                </article>
            </div>
        </section>
    }

    <section class="bm-ward-table-wrap bm-overview-table-wrap">
        <div class="bm-table-toolbar">
            <div class="bm-view-row">
                @foreach (var view in new[] { "List", "Grid", "Compact" })
                {
                    <button class="bm-ghost view @(SelectedView == view ? "active" : null)" @onclick="() => SetView(view)">@view</button>
                }
            </div>
            <div class="bm-toolbar-actions">
                <button class="bm-ghost version @(SelectedVersion=="V1"?"active":null)" @onclick='() => SetVersion("V1")'>V1 Overview</button>
                <button class="bm-ghost version @(SelectedVersion=="V2"?"active":null)" @onclick='() => SetVersion("V2")'>V2 Operational</button>
            </div>
        </div>

        @if (SelectedView == "Grid")
        {
            <div class="bm-overview-gridcards @(SelectedVersion=="V2"?"v2":null)">
                @foreach (var row in PagedRows)
                {
                    <article class="bm-overview-gridcard">
                        <header><strong title="@row.WardType">@row.Ward (@row.PhysicalBeds)</strong><span>@row.PostcodeCatchment</span></header>
                        <p>Open @row.OpenBeds • Occupied @row.OccupiedBeds • Elective @row.Elective • ED @row.EdAddons</p>
                        <p>Add-on @row.AddOnPatients • Outliers @row.Outliers • Predicted discharges @row.PredictedDischarges</p>
                        @if (SelectedVersion == "V2" && IsQchAccess)
                        {
                            var orchestration = GetWardOrchestrationSnapshot(row.Ward);
                            <div class="bm-grid-orchestration">
                                <span class="bm-state-chip">Now: @orchestration.CurrentState</span>
                                <span class="bm-state-chip">Discharge window: @orchestration.DischargeWindow</span>
                                <span class="bm-state-chip">Next: @orchestration.NextPlannedPatient</span>
                                <span class="bm-state-chip warning">Transfer: @orchestration.TransferState</span>
                                <span class="bm-state-chip critical">Staffing: @orchestration.StaffingState</span>
                            </div>
                        }
                        <div class="bm-grid-foot"><span>Delayed @row.DelayedDischarge</span><span>Actual discharges @row.ActualDischarges</span><span class="bm-action-icon-wrap"><img src="images/icons/show-blackish.png" alt="View" class="bm-action-icon" /></span></div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="bm-responsive-table">
            <table class="bm-ward-table bm-overview-table @(SelectedView == "Compact" ? "compact" : null)">
                <thead>
                    <tr>
                        @foreach (var col in CurrentColumns)
                        {
                            <th @onclick="() => SortBy(col.Key)" class="@(SortColumn == col.Key ? "sorted" : null)">@col.Label @if (SortColumn == col.Key){<span>@(SortAsc ? "↑" : "↓")</span>}</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in PagedRows)
                    {
                        <tr>
                            <td title="@row.WardType">@row.Ward (@row.PhysicalBeds)</td><td>@row.OpenBeds</td><td>@row.OccupiedBeds</td><td>@row.Elective</td><td>@row.EdAddons</td><td>@row.AddOnPatients</td><td>@row.Outliers</td><td>@row.PredictedDischarges</td><td>@row.ActualDischarges</td><td>@row.DelayedDischarge</td>
                            @if (SelectedVersion == "V2" && IsQchAccess)
                            {
                                var future = GetPredictedAvailability(row.Ward);
                                <td>
                                    <div class="bm-inline-stack"><span>@future.CurrentState</span><span>Discharge @future.PredictedDischargeTime</span><span>Next @future.NextPlannedPatient</span></div>
                                </td>
                                <td>@future.CleaningEta</td>
                            }
                            <td>@row.PostcodeCatchment</td><td><span class="bm-action-icon-wrap"><img src="images/icons/show-blackish.png" alt="View" class="bm-action-icon" /></span><span class="bm-action-icon-wrap"><img src="images/icons/edit-blackish.png" alt="Edit" class="bm-action-icon" /></span></td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    </section>
</section>

@code {
    private const string AccessStatewide = "statewide";
    private const string AccessQchBedManager = "qch-bed-manager";
    private const string QchHhs = "Children's Health Queensland";
    private const string QchFacility = "Queensland Children's Hospital";
    private int EditingNotificationId = -1;
    private bool IsCreatingNotification;
    private EditableNotification DraftNotification = new();
    private List<FacilityNotification> QchNotifications = new()
    {
        new FacilityNotification(1, "Tier 2 — Amber", "Fire alarm testing scheduled at 3pm. Please minimise non-essential patient transfers during testing window.", "amber"),
        new FacilityNotification(2, "Hospital Capacity Status: Red", "High demand across ED and inpatient flow. Prioritise confirmed discharges before 11:00.", "red")
    };
    private string QchActivityView = "Today";

    private string SelectedAccessView = AccessStatewide;
    private string SelectedHhs = DemoReferenceData.All;
    private string SelectedFacility = DemoReferenceData.All;
    private string SelectedWard = AllWards;
    private string ActiveInsightFilter = string.Empty;
    private string SelectedView = "List";
    private string SelectedVersion = "V1";
    private bool ShowInsightsPanel;
    private string SortColumn = "Ward";
    private bool SortAsc = true;
    private int CurrentPage = 1;
    private int PageSize = 12;
    private const string AllWards = "All wards";
    private bool IsQchAccess => SelectedAccessView == AccessQchBedManager;
    private IReadOnlyList<string> HhsOptions => DemoReferenceData.HhsOptions;
    private IReadOnlyList<string> FacilityOptions =>
        new[] { DemoReferenceData.All }
            .Concat(
                SelectedHhs == DemoReferenceData.All
                    ? DemoReferenceData.FacilitiesByHhs.SelectMany(x => x.Value).Distinct().Order()
                    : DemoReferenceData.FacilitiesByHhs.GetValueOrDefault(SelectedHhs, new List<string>()).Order())
            .ToList();
    private IReadOnlyList<string> WardOptions => GetAvailableWardOptions();
    private List<BedOverviewRow> FilteredRows => GetScopedBedManagementRows();
    private List<BedOverviewRow> SortedRows => SortAsc ? FilteredRows.OrderBy(GetSortValue).ToList() : FilteredRows.OrderByDescending(GetSortValue).ToList();
    private List<BedOverviewRow> PagedRows => SortedRows.Skip((CurrentPage - 1) * PageSize).Take(PageSize).ToList();

    private List<(string Key, string Label)> CurrentColumns =>
        new List<(string Key, string Label)>
        {
            ("Ward", "Ward"), ("OpenBeds", "Open Beds"), ("OccupiedBeds", "Occupied Beds"), ("Elective", "Elective Admissions"),
            ("EdAddons", "ED Admissions"), ("AddOnPatients", "Add-On Patients"), ("Outliers", "Outliers"),
            ("PredictedDischarges", "Predicted Discharges"), ("ActualDischarges", "Actual Discharges"),
            ("DelayedDischarge", "Delayed Discharges")
        }
        .Concat(SelectedVersion == "V2" && IsQchAccess
            ? new List<(string Key, string Label)> { ("FuturePlan", "Future Bed Plan"), ("CleaningEta", "Cleaning/Transfer ETA") }
            : new List<(string Key, string Label)>())
        .Concat(new List<(string Key, string Label)> { ("PostcodeCatchment", "Postcode / Catchment"), ("Actions", "Actions") })
        .ToList();

    private object GetSortValue(BedOverviewRow x) => SortColumn switch { "Ward" => x.Ward, "OpenBeds" => x.OpenBeds, "OccupiedBeds" => x.OccupiedBeds, "Elective" => x.Elective, "EdAddons" => x.EdAddons, "AddOnPatients" => x.AddOnPatients, "Outliers" => x.Outliers, "PredictedDischarges" => x.PredictedDischarges, "ActualDischarges" => x.ActualDischarges, "DelayedDischarge" => x.DelayedDischarge, "PostcodeCatchment" => x.PostcodeCatchment, _ => x.Ward };
    private void SortBy(string key) { if (key is "Actions") return; if (SortColumn == key) SortAsc = !SortAsc; else { SortColumn = key; SortAsc = true; } }
    private void SetView(string view) { SelectedView = view; CurrentPage = 1; }
    private void SetVersion(string version) { SelectedVersion = version; if (version != "V2") ShowInsightsPanel = false; }
    private string? OpenKpiInfoTitle;
    private void StartCreateNotification() { EditingNotificationId = -1; IsCreatingNotification = true; DraftNotification = new EditableNotification(); }
    private void CancelCreateNotification() { IsCreatingNotification = false; DraftNotification = new EditableNotification(); }
    private void SaveCreateNotification()
    {
        if (string.IsNullOrWhiteSpace(DraftNotification.Title) || string.IsNullOrWhiteSpace(DraftNotification.Message)) return;
        var nextId = QchNotifications.Count == 0 ? 1 : QchNotifications.Max(x => x.Id) + 1;
        QchNotifications.Add(new FacilityNotification(nextId, DraftNotification.Title.Trim(), DraftNotification.Message.Trim(), DraftNotification.Severity));
        CancelCreateNotification();
    }
    private void StartUpdateNotification(int id)
    {
        var note = QchNotifications.First(x => x.Id == id);
        EditingNotificationId = id;
        DraftNotification = new EditableNotification { Title = note.Title, Message = note.Message, Severity = note.Severity };
        IsCreatingNotification = false;
    }
    private void SaveUpdateNotification(int id)
    {
        var index = QchNotifications.FindIndex(x => x.Id == id);
        if (index < 0 || string.IsNullOrWhiteSpace(DraftNotification.Title) || string.IsNullOrWhiteSpace(DraftNotification.Message)) return;
        QchNotifications[index] = new FacilityNotification(id, DraftNotification.Title.Trim(), DraftNotification.Message.Trim(), DraftNotification.Severity);
        CancelUpdateNotification();
    }
    private void CancelUpdateNotification() { EditingNotificationId = -1; DraftNotification = new EditableNotification(); }
    private void RemoveNotification(int id)
    {
        QchNotifications.RemoveAll(x => x.Id == id);
        if (EditingNotificationId == id) CancelUpdateNotification();
    }
    private void ToggleKpiInfo(string title) => OpenKpiInfoTitle = OpenKpiInfoTitle == title ? null : title;
    private void OnQchActivityTabChanged(string tab) => QchActivityView = tab;
    private void CloseKpiInfo() => OpenKpiInfoTitle = null;
    private void HandleKeydown(KeyboardEventArgs args) { if (args.Key == "Escape") OpenKpiInfoTitle = null; }
    private string ActiveInsightTitle => ActiveInsights.FirstOrDefault(x => x.InsightKey == ActiveInsightFilter)?.Title ?? string.Empty;
    private HashSet<string> ActiveInsightWardIds =>
        ActiveInsights.FirstOrDefault(x => x.InsightKey == ActiveInsightFilter)?.RelatedWardIds
        ?? new HashSet<string>();
    private void OnAccessViewChanged() { ApplyAccessScope(); ClearInsightFilter(); }
    private void OnHhsChanged() { if (SelectedHhs != QchHhs && SelectedFacility == QchFacility) SelectedFacility = DemoReferenceData.All; }
    private void ApplyAccessScope() { if (IsQchAccess) { SelectedHhs = QchHhs; SelectedFacility = QchFacility; SelectedWard = AllWards; } else { SelectedHhs = DemoReferenceData.All; SelectedFacility = DemoReferenceData.All; SelectedWard = AllWards; } }
    private List<string> GetAvailableWardOptions()
    {
        var sourceRows = IsQchAccess
            ? Rows.Where(x => x.Hhs == QchHhs && x.Facility == QchFacility)
            : Rows.Where(x => SelectedFacility == DemoReferenceData.All || x.Facility == SelectedFacility);

        return new[] { AllWards }
            .Concat(sourceRows.Select(x => x.Ward).Distinct().Order())
            .ToList();
    }
    private IEnumerable<BedOverviewRow> GetBaseScopedRows() { IEnumerable<BedOverviewRow> scoped = Rows; if (IsQchAccess) scoped = scoped.Where(r => r.Hhs == QchHhs && r.Facility == QchFacility); else { if (SelectedHhs != DemoReferenceData.All) scoped = scoped.Where(r => r.Hhs == SelectedHhs); if (SelectedFacility != DemoReferenceData.All) scoped = scoped.Where(r => r.Facility == SelectedFacility);} if (SelectedWard != AllWards) scoped = scoped.Where(r => r.Ward == SelectedWard); return scoped; }
    private List<BedOverviewRow> GetScopedBedManagementRows() { var scoped = GetBaseScopedRows(); if (!string.IsNullOrWhiteSpace(ActiveInsightFilter)) { var ids = ActiveInsightWardIds; scoped = scoped.Where(r => ids.Contains(r.Ward)); } return scoped.ToList(); }
    private void ApplyInsightFilter(string filterKey) => ActiveInsightFilter = ActiveInsightFilter == filterKey ? string.Empty : filterKey;
    private void ClearInsightFilter() => ActiveInsightFilter = string.Empty;
    private bool IsInsightActive(string insightKey) => ActiveInsightFilter == insightKey;

    private List<SituationalInsight> ActiveInsights => BuildSituationalInsights(GetBaseScopedRows().ToList());
    private static List<SituationalInsight> BuildSituationalInsights(List<BedOverviewRow> rows)
    {
        var insights = new List<SituationalInsight>
        {
            CreateInsight("wards-over-capacity", "Wards Over Capacity", "Wards operating above safe occupancy threshold and requiring immediate focus.", "critical", "capacity", rows.Where(r => r.OccupancyValue >= 95 || r.OpenBeds <= 1), Icons.Material.Filled.Warning, "View wards"),
            CreateInsight("delayed-discharge-risk", "Delayed Discharge Risk", "Delayed flow and discharge barriers are constraining throughput.", "warning", "delayed-discharge", rows.Where(r => r.DelayedDischarge >= 3), Icons.Material.Filled.PersonOff, "Review delayed discharge"),
            CreateInsight("high-ed-pressure", "High ED Admission Pressure", "Elevated ED admission activity is loading inpatient capacity.", "high", "ed-admissions", rows.Where(r => r.EdAddons >= 3), Icons.Material.Filled.LocalHospital, "View wards"),
            CreateInsight("high-outlier-load", "Outlier Pressure", "Outlier cohorts are impacting placement flexibility.", "high", "outliers", rows.Where(r => r.Outliers >= 2), Icons.Material.Filled.SwapHoriz, "Review outliers"),
            CreateInsight("predicted-discharge-opportunity", "Predicted Discharge Opportunity", "Wards with immediate discharge opportunities to recover capacity.", "info", "predicted-discharges", rows.Where(r => r.PredictedDischarges >= 4 && r.DelayedDischarge <= 3), Icons.Material.Filled.TrendingDown, "Review predicted discharges"),
            CreateInsight("operational-escalation-risk", "Operational Escalation Risk", "Wards approaching Tier 3 pressure due to occupancy and constraints.", "critical", "escalation", rows.Where(r => (r.Pressure == "Critical" || r.Pressure == "High") && (r.OccupancyValue >= 92 || r.DelayedDischarge >= 4)), Icons.Material.Filled.CrisisAlert, "Open escalation")
        };

        return insights.Where(x => x.Count > 0).ToList();
    }

    private static SituationalInsight CreateInsight(string key, string title, string description, string severityClass, string filterType, IEnumerable<BedOverviewRow> rows, string icon, string actionLabel)
    {
        var matchedRows = rows.DistinctBy(x => x.Ward).ToList();
        return new SituationalInsight(key, title, description, severityClass, matchedRows.Select(x => x.Ward).ToHashSet(), filterType, matchedRows.Count, icon, actionLabel);
    }


    private PredictedBedState GetPredictedAvailability(string ward) =>
        PredictedBedStates.FirstOrDefault(x => x.Ward == ward)
        ?? new PredictedBedState(ward, "Occupied", "16:00", "Awaiting allocation", "TBC", "None", "Low");
    private WardOrchestrationSnapshot GetWardOrchestrationSnapshot(string ward) =>
        WardSnapshots.FirstOrDefault(x => x.Ward == ward)
        ?? new WardOrchestrationSnapshot(ward, "Occupied", "15:00-17:00", "General admission", "Awaiting transport", "Stable");
    private IReadOnlyList<OperationalEscalation> GetOperationalEscalations() => OperationalEscalations;
